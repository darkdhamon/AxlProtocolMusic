@inherits LayoutComponentBase
@inject IHostEnvironment HostEnvironment
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-end align-items-center gap-3 flex-wrap">
            <label class="theme-switch" for="theme-toggle">
                <span class="theme-switch-copy">
                    <span class="theme-switch-label">Dark Mode</span>
                    <span class="theme-switch-state">@(isDarkMode ? "On" : "Off")</span>
                </span>
                <span class="theme-switch-control">
                    <input
                        id="theme-toggle"
                        class="theme-switch-input"
                        type="checkbox"
                        @bind="isDarkMode"
                        @bind:after="HandleThemeChanged"
                        aria-label="Toggle dark mode" />
                    <span class="theme-switch-slider" aria-hidden="true"></span>
                </span>
            </label>

            @if (IsReleaseDetailsPage)
            {
                <a class="btn btn-outline-primary btn-sm" href="/releases">Back to Releases</a>
            }

            <AuthorizeView Roles="Admin">
                <Authorized>
                    @if (IsNewsPage)
                    {
                        <a class="btn btn-primary btn-sm" href="/news?editor=new">Create Article</a>
                    }
                </Authorized>
            </AuthorizeView>

            @if (HostEnvironment.IsDevelopment())
            {
                <AuthorizeView Roles="Admin">
                    <Authorized>
                        @if (IsTimelinePage)
                        {
                            <a class="btn btn-outline-primary btn-sm" href="/timeline?editor=new">Add Timeline Event</a>
                        }
                    </Authorized>
                </AuthorizeView>

                <form method="post" action="/account/reset-development-database" class="m-0">
                    <AntiforgeryToken />
                    <button
                        class="btn btn-outline-danger btn-sm"
                        type="submit"
                        onclick="return confirm('Reset the development database to seeded data? This will delete all current local development content.');">
                        Reset Dev DB
                    </button>
                </form>
            }
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

<SiteChatbot />

@implements IDisposable

@code {
    private bool isDarkMode;
    private bool shouldReapplyTheme;

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var activeTheme = await JSRuntime.InvokeAsync<string>("axlTheme.initializeTheme");
            isDarkMode = string.Equals(activeTheme, "dark", StringComparison.OrdinalIgnoreCase);
            StateHasChanged();
            return;
        }

        if (!shouldReapplyTheme)
        {
            return;
        }

        shouldReapplyTheme = false;
        await JSRuntime.InvokeVoidAsync("axlTheme.setTheme", isDarkMode ? "dark" : "light");
    }

    private bool IsTimelinePage =>
        NavigationManager.ToBaseRelativePath(NavigationManager.Uri)
            .StartsWith("timeline", StringComparison.OrdinalIgnoreCase);

    private bool IsNewsPage
    {
        get
        {
            var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
            var path = relativePath.Split('?', '#')[0].Trim('/');

            return string.Equals(path, "news", StringComparison.OrdinalIgnoreCase)
                || string.Equals(path, "news-articles", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsReleaseDetailsPage
    {
        get
        {
            var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
            var path = relativePath.Split('?', '#')[0].Trim('/');

            return path.StartsWith("releases/", StringComparison.OrdinalIgnoreCase)
                && !string.Equals(path, "releases/new", StringComparison.OrdinalIgnoreCase);
        }
    }

    private async Task HandleThemeChanged()
    {
        await JSRuntime.InvokeVoidAsync("axlTheme.setTheme", isDarkMode ? "dark" : "light");
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        shouldReapplyTheme = true;
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }
}
