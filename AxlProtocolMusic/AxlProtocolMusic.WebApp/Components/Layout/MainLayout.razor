@inherits LayoutComponentBase
@inject IHostEnvironment HostEnvironment

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center gap-3 flex-wrap">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>

            @if (HostEnvironment.IsDevelopment())
            {
                <form method="post" action="/account/reset-development-database" class="m-0">
                    <AntiforgeryToken />
                    <button
                        class="btn btn-outline-danger btn-sm"
                        type="submit"
                        onclick="return confirm('Reset the development database to seeded data? This will delete all current local development content.');">
                        Reset Dev DB
                    </button>
                </form>
            }
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
