<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <script>
        (function () {
            var storageKey = "axl-theme";

            var prefersDark = function () {
                return window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
            };

            var getStoredTheme = function () {
                try {
                    var value = window.localStorage.getItem(storageKey);
                    return value === "dark" || value === "light" ? value : null;
                } catch {
                    return null;
                }
            };

            var applyTheme = function (theme) {
                var resolvedTheme = theme === "dark" ? "dark" : "light";
                document.documentElement.setAttribute("data-theme", resolvedTheme);
                document.documentElement.style.colorScheme = resolvedTheme;
                return resolvedTheme;
            };

            window.axlTheme = {
                initializeTheme: function () {
                    return applyTheme(getStoredTheme() || (prefersDark() ? "dark" : "light"));
                },
                setTheme: function (theme) {
                    var resolvedTheme = applyTheme(theme);

                    try {
                        window.localStorage.setItem(storageKey, resolvedTheme);
                    } catch {
                    }

                    return resolvedTheme;
                }
            };

            window.axlChatbotStorage = {
                getState: function () {
                    try {
                        return window.localStorage.getItem("axl-chatbot-state") || "";
                    } catch {
                        return "";
                    }
                },
                setState: function (value) {
                    try {
                        window.localStorage.setItem("axl-chatbot-state", value || "");
                    } catch {
                    }
                },
                getTranscript: function () {
                    try {
                        return window.localStorage.getItem("axl-chatbot-transcript") || "";
                    } catch {
                        return "";
                    }
                },
                setTranscript: function (value) {
                    try {
                        window.localStorage.setItem("axl-chatbot-transcript", value || "");
                    } catch {
                    }
                }
            };

            window.axlChatbotPageContext = {
                getCurrentPage: function () {
                    var source = document.querySelector("main") || document.querySelector("article") || document.body;
                    var clone = source ? source.cloneNode(true) : null;

                    if (clone && clone.querySelectorAll) {
                        clone.querySelectorAll("script, style, noscript, .site-chatbot").forEach(function (node) {
                            node.remove();
                        });
                    }

                    var content = clone && clone.innerText
                        ? clone.innerText.replace(/\s+/g, " ").trim()
                        : "";

                    if (content.length > 4000) {
                        content = content.substring(0, 4000);
                    }

                    return {
                        pagePath: (window.location.pathname || "") + (window.location.search || ""),
                        pageTitle: document.title || "",
                        pageContent: content
                    };
                }
            };

            window.axlChatbotUi = {
                initializePanel: function (rootSelector, panelSelector, handleSelector, dotNetRef) {
                    var root = document.querySelector(rootSelector);
                    var panel = document.querySelector(panelSelector);
                    var handle = root ? root.querySelector(handleSelector) : null;
                    var viewportMargin = 16;

                    if (!root || !panel || !handle || root.dataset.chatbotUiInitialized === "true") {
                        return;
                    }

                    root.dataset.chatbotUiInitialized = "true";

                    var clamp = function (value, min, max) {
                        return Math.min(Math.max(value, min), max);
                    };

                    var constrainPanelToViewport = function () {
                        var maxPanelWidth = Math.max(240, window.innerWidth - (viewportMargin * 2));
                        var maxPanelHeight = Math.max(240, window.innerHeight - (viewportMargin * 2));

                        if (panel.offsetWidth > maxPanelWidth) {
                            panel.style.width = maxPanelWidth + "px";
                        }

                        if (panel.offsetHeight > maxPanelHeight) {
                            panel.style.height = maxPanelHeight + "px";
                        }

                        var rootRect = root.getBoundingClientRect();
                        var panelRect = panel.getBoundingClientRect();
                        var maxLeft = Math.max(viewportMargin, window.innerWidth - panelRect.width - viewportMargin);
                        var maxTop = Math.max(viewportMargin, window.innerHeight - rootRect.height - viewportMargin);
                        var nextLeft = clamp(rootRect.left, viewportMargin, maxLeft);
                        var nextTop = clamp(rootRect.top, viewportMargin, maxTop);

                        root.style.right = "auto";
                        root.style.bottom = "auto";
                        root.style.left = nextLeft + "px";
                        root.style.top = nextTop + "px";
                    };

                    var emitLayout = function () {
                        constrainPanelToViewport();

                        var rootRect = root.getBoundingClientRect();
                        var panelRect = panel.getBoundingClientRect();

                        dotNetRef.invokeMethodAsync(
                            "UpdatePanelLayout",
                            Math.round(rootRect.left),
                            Math.round(rootRect.top),
                            Math.round(panelRect.width),
                            Math.round(panelRect.height));
                    };

                    constrainPanelToViewport();

                    var dragging = false;
                    var startPointerX = 0;
                    var startPointerY = 0;
                    var startLeft = 0;
                    var startTop = 0;

                    handle.addEventListener("pointerdown", function (event) {
                        if (event.target.closest("button")) {
                            return;
                        }

                        var rootRect = root.getBoundingClientRect();
                        dragging = true;
                        startPointerX = event.clientX;
                        startPointerY = event.clientY;
                        startLeft = rootRect.left;
                        startTop = rootRect.top;

                        root.style.right = "auto";
                        root.style.bottom = "auto";

                        document.body.style.userSelect = "none";
                    });

                    window.addEventListener("pointermove", function (event) {
                        if (!dragging) {
                            return;
                        }

                        var panelRect = panel.getBoundingClientRect();
                        var rootRect = root.getBoundingClientRect();
                        var maxLeft = Math.max(viewportMargin, window.innerWidth - panelRect.width - viewportMargin);
                        var maxTop = Math.max(viewportMargin, window.innerHeight - rootRect.height - viewportMargin);
                        var nextLeft = clamp(startLeft + (event.clientX - startPointerX), viewportMargin, maxLeft);
                        var nextTop = clamp(startTop + (event.clientY - startPointerY), viewportMargin, maxTop);

                        root.style.left = nextLeft + "px";
                        root.style.top = nextTop + "px";
                    });

                    window.addEventListener("pointerup", function () {
                        if (!dragging) {
                            return;
                        }

                        dragging = false;
                        document.body.style.userSelect = "";
                        emitLayout();
                    });

                    var resizeObserver = new ResizeObserver(function () {
                        emitLayout();
                    });

                    resizeObserver.observe(panel);
                    window.addEventListener("resize", emitLayout);
                },
                resetPanel: function (rootSelector) {
                    var root = document.querySelector(rootSelector);
                    if (!root) {
                        return;
                    }

                    root.dataset.chatbotUiInitialized = "false";
                    root.style.left = "";
                    root.style.top = "";
                    root.style.right = "";
                    root.style.bottom = "";
                },
                scrollToBottom: function (selector) {
                    var element = document.querySelector(selector);
                    if (!element) {
                        return;
                    }

                    element.scrollTop = element.scrollHeight;
                }
            };

            try {
                window.axlTheme.initializeTheme();
            } catch {
                document.documentElement.setAttribute("data-theme", "light");
                document.documentElement.style.colorScheme = "light";
            }
        })();
    </script>
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["AxlProtocolMusic.WebApp.styles.css"]" />
    <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@5.3.0/dist/maplibre-gl.css" />
    <ImportMap />
    <link rel="icon" type="image/x-icon" href="favicon.ico?v=2" />
    <link rel="icon" type="image/png" href="favicon.png?v=2" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <PageAnalyticsTracker />
    <ReconnectModal />
    <script src="https://unpkg.com/maplibre-gl@5.3.0/dist/maplibre-gl.js"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
