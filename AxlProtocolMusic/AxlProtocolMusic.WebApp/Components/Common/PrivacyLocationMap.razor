@rendermode InteractiveServer
@inject IJSRuntime JsRuntime
@inject IConfiguration Configuration
@implements IAsyncDisposable

<div class="privacy-location-map-shell">
    <div class="privacy-location-map-header">
        <div>
            <p class="privacy-location-map-title">Unique coarse locations</p>
            <p class="privacy-location-map-subtitle">
                @Locations.Count location@(Locations.Count == 1 ? string.Empty : "s") plotted from this browser's opted-in coarse location data.
            </p>
        </div>

        @if (Locations.Count > 0)
        {
            <p class="privacy-location-map-focus">
                Focus: @GetDisplayLabel(Locations[0].Label)
            </p>
        }
    </div>

    <div class="privacy-location-map" id="@MapElementId"></div>

    @if (Locations.Count > 0)
    {
        <div class="privacy-location-map-legend">
            @foreach (var location in Locations.Take(3))
            {
                <span class="privacy-location-chip">
                    @GetDisplayLabel(location.Label)
                    <strong>@location.Count</strong>
                </span>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public IReadOnlyList<PrivacyMapLocation> Locations { get; set; } = [];

    private readonly string MapElementId = $"privacy-location-map-{Guid.NewGuid():N}";
    private IJSObjectReference? module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "/js/privacyLocationMap.js");
        }

        if (module is null)
        {
            return;
        }

        try
        {
            await module.InvokeVoidAsync("renderPrivacyLocationMap", MapElementId, Locations, GetStyleUrl());
        }
        catch (JSDisconnectedException)
        {
            // Ignore disconnects during navigation or teardown.
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (module is not null)
        {
            try
            {
                await module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Ignore disconnects during disposal.
            }
        }
    }

    public sealed class PrivacyMapLocation
    {
        public string Label { get; set; } = string.Empty;

        public double Latitude { get; set; }

        public double Longitude { get; set; }

        public int Count { get; set; }
    }

    private string GetStyleUrl()
    {
        var explicitStyleUrl = Configuration["MapSettings:PrivacyLocationStyleUrl"];
        if (!string.IsNullOrWhiteSpace(explicitStyleUrl))
        {
            return explicitStyleUrl;
        }

        var mapTilerKey = Configuration["MapSettings:MapTilerKey"];
        if (!string.IsNullOrWhiteSpace(mapTilerKey))
        {
            return $"https://api.maptiler.com/maps/streets-v2/style.json?key={Uri.EscapeDataString(mapTilerKey)}";
        }

        return string.Empty;
    }

    private static string GetDisplayLabel(string? label)
    {
        if (string.IsNullOrWhiteSpace(label))
        {
            return "Region Unknown";
        }

        var parts = label
            .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .ToList();

        if (parts.Count == 0)
        {
            return "Region Unknown";
        }

        parts[0] = NormalizePlaceName(parts[0]);

        if (parts.Count >= 2)
        {
            parts[1] = AbbreviateState(parts[1]);
        }

        if (parts.Count >= 3)
        {
            parts[2] = AbbreviateCountry(parts[2]);
        }

        return string.Join(", ", parts.Take(3));
    }

    private static string NormalizePlaceName(string value)
    {
        var trimmed = value.Trim();
        if (trimmed.StartsWith("Township of ", StringComparison.OrdinalIgnoreCase))
        {
            trimmed = trimmed["Township of ".Length..];
        }

        if (trimmed.EndsWith(" Township", StringComparison.OrdinalIgnoreCase))
        {
            trimmed = trimmed[..^" Township".Length].Trim();
        }

        return trimmed;
    }

    private static string AbbreviateCountry(string value)
    {
        return value.Trim() switch
        {
            "United States of America (the)" => "USA",
            "United States" => "USA",
            "United Kingdom of Great Britain and Northern Ireland (the)" => "UK",
            _ => value.Trim()
        };
    }

    private static string AbbreviateState(string value)
    {
        return value.Trim() switch
        {
            "Alabama" => "AL",
            "Alaska" => "AK",
            "Arizona" => "AZ",
            "Arkansas" => "AR",
            "California" => "CA",
            "Colorado" => "CO",
            "Connecticut" => "CT",
            "Delaware" => "DE",
            "Florida" => "FL",
            "Georgia" => "GA",
            "Hawaii" => "HI",
            "Idaho" => "ID",
            "Illinois" => "IL",
            "Indiana" => "IN",
            "Iowa" => "IA",
            "Kansas" => "KS",
            "Kentucky" => "KY",
            "Louisiana" => "LA",
            "Maine" => "ME",
            "Maryland" => "MD",
            "Massachusetts" => "MA",
            "Michigan" => "MI",
            "Minnesota" => "MN",
            "Mississippi" => "MS",
            "Missouri" => "MO",
            "Montana" => "MT",
            "Nebraska" => "NE",
            "Nevada" => "NV",
            "New Hampshire" => "NH",
            "New Jersey" => "NJ",
            "New Mexico" => "NM",
            "New York" => "NY",
            "North Carolina" => "NC",
            "North Dakota" => "ND",
            "Ohio" => "OH",
            "Oklahoma" => "OK",
            "Oregon" => "OR",
            "Pennsylvania" => "PA",
            "Rhode Island" => "RI",
            "South Carolina" => "SC",
            "South Dakota" => "SD",
            "Tennessee" => "TN",
            "Texas" => "TX",
            "Utah" => "UT",
            "Vermont" => "VT",
            "Virginia" => "VA",
            "Washington" => "WA",
            "West Virginia" => "WV",
            "Wisconsin" => "WI",
            "Wyoming" => "WY",
            _ => value.Trim()
        };
    }
}
