@page "/admin"
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Admin Dashboard</PageTitle>

<h1>Admin Dashboard</h1>

<p>This is a placeholder admin area for managing Axl Protocol Music content.</p>

<section class="mt-4">
    <h2>Planned controls</h2>
    <ul>
        <li>Edit page content without redeploying</li>
        <li>Manage releases, artist info, and timeline entries</li>
        <li>Review and prune saved content versions manually</li>
    </ul>
</section>

<section class="mt-4">
    <a class="btn btn-outline-primary" href="/account/edit">Edit Login Details</a>
</section>
