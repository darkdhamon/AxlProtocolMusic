@page "/not-found"
@layout MainLayout

<PageTitle>Page Not Found</PageTitle>

<div class="not-found-page">
    <section class="not-found-shell">
        <div class="not-found-copy">
            <p class="eyebrow">404 Error</p>
            <h1>Page not found</h1>
            <p class="lead">
                The page you requested does not exist or may have moved.
            </p>
            <p>
                Use the site navigation to get back to the section you were looking for.
            </p>
        </div>

        <div class="not-found-artwork">
            <img src="/Assets/Misc/404-Graphic.png" alt="Stylized 404 graphic" />
        </div>
    </section>

    <section class="recommendations-section" aria-labelledby="you-might-like-heading">
        <div class="recommendations-header">
            <p class="eyebrow">You Might Like</p>
            <h2 id="you-might-like-heading">A couple of places to jump back in</h2>
        </div>

        <div class="recommendations-grid">
            <article class="recommendation-card recommendation-card-news">
                <div class="recommendation-card-overlay">
                    <p class="recommendation-label">News Article</p>
                    <h3>Behind the latest release</h3>
                    <p>
                        Catch up on a featured article with studio notes, release context, and the story behind the latest update.
                    </p>
                    <a class="recommendation-link" href="/news">View Article</a>
                </div>
            </article>

            <article class="recommendation-card recommendation-card-release">
                <div class="recommendation-card-overlay">
                    <p class="recommendation-label">Release</p>
                    <h3>Explore a featured release</h3>
                    <p>
                        Jump back into the catalog and open a release page with artwork, credits, lyrics, and listening links.
                    </p>
                    <a class="recommendation-link" href="/releases">View Release</a>
                </div>
            </article>
        </div>
    </section>
</div>
