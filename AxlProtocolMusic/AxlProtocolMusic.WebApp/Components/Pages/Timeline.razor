@page "/timeline"
@rendermode InteractiveServer
@using System.Text.RegularExpressions
@inject IJSRuntime JSRuntime
@inject IReleaseService ReleaseService
@inject INewsArticleService NewsArticleService
@inject ITimelineEventService TimelineEventService
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<script>
    window.axlTimelinePage = window.axlTimelinePage || (() => {
        let observer;

        function initializeInfiniteScroll(sentinel, dotNetReference) {
            if (!sentinel || !dotNetReference) {
                return;
            }

            disposeInfiniteScroll();

            observer = new IntersectionObserver(entries => {
                const visibleEntry = entries.find(entry => entry.isIntersecting);
                if (!visibleEntry) {
                    return;
                }

                dotNetReference.invokeMethodAsync("LoadMoreFromScroll");
            }, {
                root: null,
                rootMargin: "0px 0px 400px 0px",
                threshold: 0.1
            });

            observer.observe(sentinel);
        }

        function disposeInfiniteScroll() {
            if (observer) {
                observer.disconnect();
                observer = null;
            }
        }

        return {
            initializeInfiniteScroll,
            disposeInfiniteScroll
        };
    })();
</script>

<PageTitle>Timeline</PageTitle>

@if (isLoading)
{
    <p><em>Loading timeline...</em></p>
}
else
{
    <div class="timeline-page">
        <section class="timeline-hero">
            <div class="timeline-hero-copy">
                <p class="eyebrow">Project History</p>
                <h1>The Axl Protocol Timeline</h1>
                <p class="hero-lead">
                    A chronology of releases, news articles, milestones, and defining moments across the Axl Protocol story.
                </p>
                <p class="hero-body">
                    Follow how major life events, creative decisions, official releases, and editorial updates connect across time, with the
                    newest moments appearing first.
                </p>
            </div>

            <div class="timeline-hero-panel">
                <p class="panel-label">At A Glance</p>
                <div class="timeline-stats">
                    <div>
                        <span class="stat-number">@totalTimelineEvents</span>
                        <span class="stat-label">total moments</span>
                    </div>
                    <div>
                        <span class="stat-number">@releaseEventCount</span>
                        <span class="stat-label">releases</span>
                    </div>
                    <div>
                        <span class="stat-number">@newsArticleEventCount</span>
                        <span class="stat-label">news articles</span>
                    </div>
                    <div>
                        <span class="stat-number">@manualEventCount</span>
                        <span class="stat-label">timeline events</span>
                    </div>
                </div>
            </div>
        </section>

        <section class="timeline-track">
            @foreach (var month in timelineYears)
            {
                <article class="era-section">
                    <div class="era-events">
                        <div class="era-header">
                            <div class="era-marker">
                                <span class="era-year">@month.MonthLabelShort</span>
                            </div>
                        </div>

                        <div class="timeline-event-center"></div>

                        <div class="timeline-event-list">
                            @foreach (var timelineEvent in month.Events)
                            {
                                <article class="event-card">
                                    <div class="event-meta">
                                        <span class="event-date">@timelineEvent.DateLabel</span>
                                        <span class="event-tag @timelineEvent.TagClass">@timelineEvent.Tag</span>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(timelineEvent.ImageUrl))
                                    {
                                        <div class="event-artwork">
                                            <img src="@timelineEvent.ImageUrl" alt="@($"{timelineEvent.Title} image")" />
                                        </div>
                                    }

                                    <h3>@timelineEvent.Title</h3>
                                    <p>@timelineEvent.Description</p>

                                    @if (timelineEvent.Highlights.Count > 0)
                                    {
                                        <ul class="event-highlights">
                                            @foreach (var highlight in timelineEvent.Highlights)
                                            {
                                                <li>@highlight</li>
                                            }
                                        </ul>
                                    }

                                    <div class="event-card-footer">
                                        @if (!string.IsNullOrWhiteSpace(timelineEvent.Href))
                                        {
                                            <a class="event-link" href="@timelineEvent.Href">@timelineEvent.LinkLabel</a>
                                        }

                                        <AuthorizeView Roles="Admin">
                                            <Authorized>
                                                @if (timelineEvent.IsManualEvent)
                                                {
                                                    <div class="event-admin-actions">
                                                        <button
                                                            class="btn btn-outline-primary btn-sm event-edit-button"
                                                            type="button"
                                                            @onclick="() => OpenEditModal(timelineEvent)">
                                                            Edit Event
                                                        </button>

                                                        <button
                                                            class="btn btn-outline-danger btn-sm"
                                                            type="button"
                                                            @onclick="() => OpenDeleteModal(timelineEvent)">
                                                            Delete
                                                        </button>
                                                    </div>
                                                }
                                            </Authorized>
                                        </AuthorizeView>
                                    </div>
                                </article>
                            }
                        </div>
                    </div>
                </article>
            }
        </section>

        @if (hasMoreMonths)
        {
            <div class="timeline-scroll-loader">
                <div @ref="loadMoreSentinel" class="timeline-scroll-sentinel" aria-hidden="true"></div>
                <p>@(isLoadingMore ? "Loading older months..." : "Scroll to load older months.")</p>
            </div>
        }
        else if (!isLoading)
        {
            <div class="timeline-scroll-loader is-complete">
                <p>All timeline months are loaded.</p>
            </div>
        }

    </div>
}

@if (isEditModalOpen)
{
    <div class="timeline-modal-backdrop" @onclick="CloseEditModal">
        <div class="timeline-modal" @onclick:stopPropagation="true">
            <div class="timeline-modal-header">
                <div>
                    <p class="eyebrow">Admin</p>
                    <h2>Edit Timeline Event</h2>
                </div>
                <button class="btn-close" type="button" aria-label="Close" @onclick="CloseEditModal"></button>
            </div>

            @if (!string.IsNullOrWhiteSpace(editErrorMessage))
            {
                <div class="alert alert-danger" role="alert">@editErrorMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(editStatusMessage))
            {
                <div class="alert alert-success" role="alert">@editStatusMessage</div>
            }

            @if (editableTimelineEvent is not null)
            {
                <div class="timeline-modal-form">
                    <div class="form-grid">
                        <div>
                            <label class="form-label" for="timeline-title">Title</label>
                            <input
                                class="form-control"
                                id="timeline-title"
                                @bind="editableTimelineEvent.Title"
                                @bind:event="oninput" />
                        </div>

                        <div>
                            <label class="form-label" for="timeline-date">Event Date</label>
                            <input
                                class="form-control"
                                id="timeline-date"
                                type="date"
                                @bind="editableEventDate"
                                @bind:format="yyyy-MM-dd" />
                        </div>
                    </div>

                    <div class="form-grid">
                        <div>
                            <label class="form-label" for="timeline-type">Event Type</label>
                            <InputSelect class="form-select" id="timeline-type" @bind-Value="editableTimelineEvent.EventType">
                                @foreach (var eventType in timelineEventTypes)
                                {
                                    <option value="@eventType">@GetTimelineEventTag(eventType)</option>
                                }
                            </InputSelect>
                        </div>

                        <div>
                            <label class="form-label" for="timeline-image">Image Url</label>
                            <input
                                class="form-control"
                                id="timeline-image"
                                @bind="editableTimelineEvent.ImageUrl"
                                @bind:event="oninput" />
                        </div>
                    </div>

                    <div>
                        <label class="form-label" for="timeline-description">Short Description</label>
                        <textarea
                            class="form-control"
                            id="timeline-description"
                            @bind="editableTimelineEvent.ShortDescription"
                            @bind:event="oninput"
                            rows="5"></textarea>
                    </div>

                    <div class="timeline-modal-actions">
                        <button class="btn btn-outline-secondary" type="button" @onclick="CloseEditModal">Cancel</button>
                        <button class="btn btn-primary" type="button" @onclick="SaveTimelineEventAsync" disabled="@isSavingEdit">
                            @(isSavingEdit ? "Saving..." : (isCreatingTimelineEvent ? "Create Event" : "Save Changes"))
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
}

@if (isDeleteModalOpen && timelineEventPendingDelete is not null)
{
    <div class="timeline-modal-backdrop" @onclick="CloseDeleteModal">
        <div class="timeline-modal timeline-confirm-modal" @onclick:stopPropagation="true">
            <div class="timeline-modal-header">
                <div>
                    <p class="eyebrow">Admin</p>
                    <h2>Delete Timeline Event</h2>
                </div>
                <button class="btn-close" type="button" aria-label="Close" @onclick="CloseDeleteModal"></button>
            </div>

            @if (!string.IsNullOrWhiteSpace(deleteErrorMessage))
            {
                <div class="alert alert-danger" role="alert">@deleteErrorMessage</div>
            }

            <p class="confirm-copy">
                Delete <strong>@timelineEventPendingDelete.Title</strong>? This action cannot be undone.
            </p>

            <div class="timeline-modal-actions">
                <button class="btn btn-outline-secondary" type="button" @onclick="CloseDeleteModal">Cancel</button>
                <button class="btn btn-danger" type="button" @onclick="DeleteTimelineEventAsync" disabled="@isDeletingEvent">
                    @(isDeletingEvent ? "Deleting..." : "Delete Event")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private static readonly IReadOnlyList<TimelineEventType> timelineEventTypes = Enum
        .GetValues<TimelineEventType>()
        .ToList();
    private const int MonthBatchSize = 4;

    private List<TimelineMonthSection> allTimelineMonths = [];
    private List<TimelineMonthSection> timelineYears = [];
    private bool isLoading = true;
    private int releaseEventCount;
    private int newsArticleEventCount;
    private int manualEventCount;
    private int totalTimelineEvents;
    private bool isEditModalOpen;
    private bool isSavingEdit;
    private bool isCreatingTimelineEvent;
    private bool isDeleteModalOpen;
    private bool isDeletingEvent;
    private bool hasMoreMonths;
    private bool isLoadingMore;
    private bool observerInitialized;
    private string? editErrorMessage;
    private string? editStatusMessage;
    private string? deleteErrorMessage;
    private TimelineEvent? editableTimelineEvent;
    private TimelineEntry? timelineEventPendingDelete;
    private DateTime editableEventDate;
    private DotNetObjectReference<Timeline>? dotNetReference;
    private ElementReference loadMoreSentinel;

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;
        await LoadTimelineAsync();
        OpenCreateModalIfRequested();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if ((!firstRender && observerInitialized) || !hasMoreMonths)
        {
            return;
        }

        dotNetReference ??= DotNetObjectReference.Create(this);
        await JSRuntime.InvokeVoidAsync("axlTimelinePage.initializeInfiniteScroll", loadMoreSentinel, dotNetReference);
        observerInitialized = true;
    }

    [JSInvokable]
    public async Task LoadMoreFromScroll()
    {
        if (!hasMoreMonths || isLoadingMore)
        {
            return;
        }

        isLoadingMore = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(180);
        LoadNextMonthBatch();
        isLoadingMore = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadTimelineAsync()
    {
        var loadedMonthCount = timelineYears.Count;

        var releaseResult = await ReleaseService.GetPagedReleasesAsync(
            searchTerm: null,
            pageNumber: 1,
            pageSize: 250);
        var newsArticles = await NewsArticleService.GetArticlesAsync();
        var timelineEvents = await TimelineEventService.GetAllAsync();

        var releaseEvents = releaseResult.Items
            .Select(release => new TimelineEntry(
                null,
                release.ReleaseDateUtc,
                "Release",
                "release-event",
                release.Title,
                release.ShortDescription,
                BuildReleaseHighlights(release),
                release.CoverImageUrl,
                false,
                null,
                $"/releases/{Uri.EscapeDataString(release.Slug)}",
                "View Release"))
            .ToList();

        var newsArticleEvents = newsArticles
            .Select(article => new TimelineEntry(
                null,
                article.PublicationDateUtc,
                "News",
                "news-event",
                article.Title,
                BuildNewsDescription(article),
                [],
                article.ImageUrl,
                false,
                null,
                "/news",
                "View Article"))
            .ToList();

        var manualEvents = timelineEvents
            .Select(timelineEvent => new TimelineEntry(
                timelineEvent.Id,
                timelineEvent.EventDateUtc,
                GetTimelineEventTag(timelineEvent.EventType),
                "timeline-event",
                timelineEvent.Title,
                timelineEvent.ShortDescription,
                [],
                timelineEvent.ImageUrl,
                true,
                timelineEvent.EventType,
                null,
                null))
            .ToList();

        releaseEventCount = releaseEvents.Count;
        newsArticleEventCount = newsArticleEvents.Count;
        manualEventCount = manualEvents.Count;

        var combinedEvents = releaseEvents
            .Concat(newsArticleEvents)
            .Concat(manualEvents)
            .OrderByDescending(item => item.EventDateUtc)
            .ToList();

        totalTimelineEvents = combinedEvents.Count;

        allTimelineMonths = combinedEvents
            .GroupBy(item => new DateTime(item.EventDateUtc.Year, item.EventDateUtc.Month, 1))
            .OrderByDescending(group => group.Key)
            .Select(group => new TimelineMonthSection(
                group.Key.ToString("MMM yyyy"),
                group.ToList()))
            .ToList();

        timelineYears = [];
        LoadNextMonthBatch(Math.Max(loadedMonthCount, MonthBatchSize));
        isLoading = false;
    }

    private void LoadNextMonthBatch(int? targetCount = null)
    {
        var nextCount = targetCount ?? (timelineYears.Count + MonthBatchSize);
        timelineYears = allTimelineMonths
            .Take(Math.Min(nextCount, allTimelineMonths.Count))
            .ToList();

        hasMoreMonths = timelineYears.Count < allTimelineMonths.Count;
    }

    private static IReadOnlyList<string> BuildReleaseHighlights(ReleaseListItemViewModel release)
    {
        return [];
    }

    private static string BuildNewsDescription(NewsArticle article)
    {
        var words = Regex.Split(article.Content.Trim(), @"\s+")
            .Where(word => !string.IsNullOrWhiteSpace(word))
            .ToList();

        if (words.Count <= 28)
        {
            return string.Join(' ', words);
        }

        return $"{string.Join(' ', words.Take(28))}...";
    }

    private void OpenEditModal(TimelineEntry timelineEvent)
    {
        if (!timelineEvent.IsManualEvent || string.IsNullOrWhiteSpace(timelineEvent.Id))
        {
            return;
        }

        isCreatingTimelineEvent = false;
        editableTimelineEvent = new TimelineEvent
        {
            Id = timelineEvent.Id,
            Title = timelineEvent.Title,
            ShortDescription = timelineEvent.Description,
            ImageUrl = timelineEvent.ImageUrl ?? string.Empty,
            EventDateUtc = timelineEvent.EventDateUtc,
            EventType = timelineEvent.EventType ?? TimelineEventType.Milestone
        };

        editableEventDate = timelineEvent.EventDateUtc.UtcDateTime.Date;
        editErrorMessage = null;
        editStatusMessage = null;
        isEditModalOpen = true;
    }

    private void OpenCreateModal()
    {
        isCreatingTimelineEvent = true;
        editableTimelineEvent = new TimelineEvent
        {
            EventDateUtc = DateTimeOffset.UtcNow.Date,
            EventType = TimelineEventType.Milestone
        };
        editableEventDate = DateTime.UtcNow.Date;
        editErrorMessage = null;
        editStatusMessage = null;
        isEditModalOpen = true;
    }

    private void OpenDeleteModal(TimelineEntry timelineEvent)
    {
        if (!timelineEvent.IsManualEvent || string.IsNullOrWhiteSpace(timelineEvent.Id))
        {
            return;
        }

        timelineEventPendingDelete = timelineEvent;
        deleteErrorMessage = null;
        isDeleteModalOpen = true;
    }

    private void CloseEditModal()
    {
        if (isSavingEdit)
        {
            return;
        }

        isEditModalOpen = false;
        isCreatingTimelineEvent = false;
        editableTimelineEvent = null;
        editErrorMessage = null;
        editStatusMessage = null;
        RemoveEditorQueryParameter();
    }

    private void CloseDeleteModal()
    {
        if (isDeletingEvent)
        {
            return;
        }

        isDeleteModalOpen = false;
        timelineEventPendingDelete = null;
        deleteErrorMessage = null;
    }

    private async Task SaveTimelineEventAsync()
    {
        if (editableTimelineEvent is null)
        {
            return;
        }

        isSavingEdit = true;
        editErrorMessage = null;
        editStatusMessage = null;

        try
        {
            editableTimelineEvent.EventDateUtc = new DateTimeOffset(
                editableEventDate.Year,
                editableEventDate.Month,
                editableEventDate.Day,
                0,
                0,
                0,
                TimeSpan.Zero);

            if (isCreatingTimelineEvent)
            {
                await TimelineEventService.CreateAsync(editableTimelineEvent);
            }
            else
            {
                await TimelineEventService.UpdateAsync(editableTimelineEvent);
            }

            await LoadTimelineAsync();

            editStatusMessage = isCreatingTimelineEvent
                ? "Timeline event created."
                : "Timeline event updated.";
            isEditModalOpen = false;
            isCreatingTimelineEvent = false;
            editableTimelineEvent = null;
            RemoveEditorQueryParameter();
        }
        catch (Exception exception)
        {
            editErrorMessage = exception.Message;
        }
        finally
        {
            isSavingEdit = false;
        }
    }

    private async Task DeleteTimelineEventAsync()
    {
        if (timelineEventPendingDelete is null || string.IsNullOrWhiteSpace(timelineEventPendingDelete.Id))
        {
            return;
        }

        isDeletingEvent = true;
        deleteErrorMessage = null;

        try
        {
            await TimelineEventService.DeleteAsync(timelineEventPendingDelete.Id);
            await LoadTimelineAsync();
            isDeleteModalOpen = false;
            timelineEventPendingDelete = null;
        }
        catch (Exception exception)
        {
            deleteErrorMessage = exception.Message;
        }
        finally
        {
            isDeletingEvent = false;
        }
    }

    private static string GetTimelineEventTag(TimelineEventType eventType) => eventType switch
    {
        TimelineEventType.Research => "Research",
        TimelineEventType.Creative => "Creative",
        TimelineEventType.Planning => "Planning",
        TimelineEventType.Identity => "Identity",
        TimelineEventType.Release => "Release",
        TimelineEventType.Platform => "Platform",
        TimelineEventType.LifeEvent => "Life Event",
        _ => "Milestone"
    };

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        OpenCreateModalIfRequested();
        _ = InvokeAsync(StateHasChanged);
    }

    private void OpenCreateModalIfRequested()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("editor", out var editorMode)
            && string.Equals(editorMode.ToString(), "new", StringComparison.OrdinalIgnoreCase)
            && !isEditModalOpen)
        {
            OpenCreateModal();
        }
    }

    private void RemoveEditorQueryParameter()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query)
            .Where(entry => !string.Equals(entry.Key, "editor", StringComparison.OrdinalIgnoreCase))
            .ToDictionary(entry => entry.Key, entry => (string?)entry.Value.ToString());

        var baseUri = uri.GetLeftPart(UriPartial.Path);
        var targetUri = query.Count == 0
            ? baseUri
            : Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(baseUri, query);

        NavigationManager.NavigateTo(targetUri, replace: true);
    }

    private sealed record TimelineMonthSection(
        string MonthLabelShort,
        IReadOnlyList<TimelineEntry> Events);

    private sealed record TimelineEntry(
        string? Id,
        DateTimeOffset EventDateUtc,
        string Tag,
        string TagClass,
        string Title,
        string Description,
        IReadOnlyList<string> Highlights,
        string? ImageUrl,
        bool IsManualEvent,
        TimelineEventType? EventType,
        string? Href,
        string? LinkLabel)
    {
        public string DateLabel => EventDateUtc.ToString("MMMM d, yyyy");
    }

    public async ValueTask DisposeAsync()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
        try
        {
            await JSRuntime.InvokeVoidAsync("axlTimelinePage.disposeInfiniteScroll");
        }
        catch
        {
        }

        dotNetReference?.Dispose();
    }
}
