@page "/privacy"
@rendermode InteractiveServer
@inject IAnalyticsService AnalyticsService
@inject IPrivacyPreferencesService PrivacyPreferencesService
@inject IHttpContextAccessor HttpContextAccessor
@* Reminder: whenever this privacy page content changes, update the LastUpdated date below. *@

<PageTitle>Privacy</PageTitle>

@if (isLoading)
{
    <p><em>Loading privacy settings...</em></p>
}
else
{
    <div class="privacy-page">
        <section class="privacy-hero">
            <div class="privacy-hero-copy">
                <p class="eyebrow">Privacy</p>
                <h1>Your Data And This Site</h1>
                <p class="last-updated">Last updated @LastUpdated.ToString("MMMM d, yyyy")</p>
                <p class="hero-lead">
                    Minimal data is collected and used only for the purpose of learning what features of the site are
                    valuable to visitors. Axl Protocol Music keeps analytics intentionally lightweight so the site can
                    improve over time without turning into a surveillance tool.
                </p>
            </div>

            <div class="privacy-hero-panel">
                <p class="panel-label">Current Baseline</p>
                <ul class="hero-points">
                    <li>page visits and approximate time on page</li>
                    <li>outbound link clicks grouped by platform, such as streaming services, stores, or social destinations</li>
                    <li>a repeat-visitor cookie for aggregate metrics, enabled by default</li>
                    <li>coarse region data only when hosting or proxy data makes it available</li>
                    <li>optional coarse browser location for city/state/country reporting and a 25-mile privacy radius map</li>
                    <li>no planned automatic deletion of metric data based on time</li>
                    <li>admin traffic excluded from reporting</li>
                    <li>no sale of visitor or user data to third parties</li>
                </ul>
            </div>
        </section>

        <section class="privacy-grid">
            <article class="privacy-card">
                <p class="eyebrow">What Is Collected</p>
                <h2>Essential Site Analytics</h2>
                <ul class="privacy-list">
                    <li>the path of the page you visited</li>
                    <li>how long that page stayed open in your browser</li>
                    <li>which external links you click, such as streaming services, digital stores, or social links</li>
                    <li>a server-issued repeat-visitor identifier stored in an essential cookie</li>
                    <li>approximate visitor region when a hosting edge, proxy, or CDN provides it</li>
                    <li>the previous page path when available</li>
                </ul>
                <p class="supporting-copy">
                    This baseline data is used to understand what content people actually use, which destinations are most useful,
                    and how the site can improve over time.
                </p>
                <p class="supporting-copy">
                    Basic metrics data is enabled by default, and the related repeat-visitor cookie is currently treated as essential.
                </p>
                <p class="supporting-copy">
                    There is currently no planned automatic deletion schedule for metric data based on time alone.
                </p>
            </article>

            <article class="privacy-card accent-card">
                <p class="eyebrow">What Is Not Collected By Default</p>
                <h2>No Precise Location Tracking Or Public Accounts</h2>
                <p>
                    This site does not request your browser GPS location by default, and it does not use exact latitude or
                    longitude for routine analytics.
                </p>
                <p>
                    If geographic data is available through hosting or proxy infrastructure, or if you opt in to browser location
                    sharing, only coarse location information such as city, state, and country would be retained. Exact location,
                    if available anywhere upstream or in the browser permission flow, is never saved.
                </p>
                <p>
                    For opted-in location maps, a separately stored rounded coordinate pair may also be retained, but only
                    at a coarse precision intended to avoid accuracy better than roughly a 25-mile area. On the collected-data
                    page, that appears as a shaded privacy radius rather than a precise GPS point.
                </p>
                <p>
                    User accounts are not currently available for normal visitors. Accounts may be added later only if future site
                    features require them.
                </p>
                <p>
                    User or visitor data collected through this site will never be sold to third parties.
                </p>
            </article>
        </section>

        <section class="privacy-grid">
            <article class="privacy-card">
                <p class="eyebrow">Third-Party Processing</p>
                <h2>Limited Third-Party Location Processing</h2>
                <p>
                    Most analytics data is processed directly by this site. If you opt in to browser location sharing, a client-side
                    reverse geocoding service is used to translate your current coordinates into a city, state, and country label.
                </p>
                <p>
                    That third-party step is only used for the opted-in location feature. The resulting stored values are limited to
                    a city/state/country style label for reports and a separately rounded coarse coordinate pair for map plotting.
                </p>
                <p>
                    If you later turn approximate location sharing off, previously collected location-related analytics for this
                    browser are cleared while non-location visit and click records remain intact.
                </p>
            </article>

            <article class="privacy-card">
                <p class="eyebrow">Admin Traffic</p>
                <h2>Reporting Is Kept Clearer On Purpose</h2>
                <p>
                    Admin traffic is excluded from reporting in order to reduce skewed analytics results while the site is being
                    updated, tested, and managed.
                </p>
                <p>
                    When an admin signs in, that browser is marked so future analytics from it can continue to be excluded.
                </p>
            </article>
        </section>

        <section class="privacy-card">
            <p class="eyebrow">Policy Updates</p>
            <h2>This Page Will Change Over Time</h2>
            <p>
                The privacy page will be updated as the site evolves. Separate notices are not planned at this time, so the page
                itself will remain the source of truth for current privacy practices.
            </p>
            <p>
                The last updated date at the top of this page shows when the privacy policy was most recently revised.
            </p>
        </section>

        <section class="privacy-card preference-card">
            <p class="eyebrow">Privacy Preferences</p>
            <h2>Optional Metrics And Future Consent</h2>
            <p class="supporting-copy">
                These switches are stored in your browser and are meant for optional analytics features that may be added later.
                Preferences save automatically when you change them.
            </p>
            <p class="supporting-copy">
                You can also review the analytics currently tied to this browser on the collected-data page, including grouped page visits,
                grouped external link clicks by platform, and any saved coarse location map data.
            </p>

            @if (!string.IsNullOrWhiteSpace(statusMessage))
            {
                <div class="alert alert-success" role="alert">@statusMessage</div>
            }

            <div class="preference-list">
                <div class="preference-row disabled-row">
                    <div>
                        <h3>Essential Site Analytics</h3>
                        <p>
                            Required for aggregate page-visit reporting, time-on-page metrics, repeat-visitor counts, and outbound-link click totals.
                            Basic metrics data is enabled by default, and the related cookie is currently marked as essential.
                        </p>
                        @if (!canDisableEssentialMetrics)
                        {
                            <p class="preference-note">
                                This control stays disabled until the site reaches at least @MinimumUniqueVisitors unique visitors.
                                Current unique visitors: @uniqueVisitorCount.
                            </p>
                        }
                        else
                        {
                            <p class="preference-note">
                                Turning this off will stop future essential analytics for this browser and delete existing analytics tied to this visitor id.
                            </p>
                        }
                    </div>
                    <label class="switch">
                        <input type="checkbox" checked="@preferences.AllowEssentialSiteMetrics" @onchange="HandleEssentialMetricsChanged" disabled="@(!canDisableEssentialMetrics)" />
                        <span class="slider"></span>
                    </label>
                </div>

                <div class="preference-row">
                    <div>
                        <h3>Approximate Location Sharing</h3>
                        <p>When enabled, the browser may ask for location permission so this site can store city, state, and country for reports plus a separately rounded coarse map point for analytics maps. Exact coordinates would not be saved.</p>
                        <p class="preference-note">Turning this off removes previously stored location-related analytics for this browser.</p>
                    </div>
                    <label class="switch">
                        <input type="checkbox" checked="@preferences.ShareApproximateLocation" @onchange="HandleApproximateLocationChanged" />
                        <span class="slider"></span>
                    </label>
                </div>

                <div class="preference-row">
                    <div>
                        <h3>Enhanced Engagement Metrics</h3>
                        <p>Allow future engagement analysis such as deeper reading behavior or richer interaction timing.</p>
                    </div>
                    <label class="switch">
                        <input type="checkbox" checked="@preferences.AllowEnhancedEngagementMetrics" @onchange="HandleEnhancedEngagementChanged" />
                        <span class="slider"></span>
                    </label>
                </div>

                <div class="preference-row">
                    <div>
                        <h3>Personalization Metrics</h3>
                        <p>Allow future audience insights that could support personalized content recommendations or featured sections.</p>
                    </div>
                    <label class="switch">
                        <input type="checkbox" checked="@preferences.AllowPersonalizationMetrics" @onchange="HandlePersonalizationChanged" />
                        <span class="slider"></span>
                    </label>
                </div>
            </div>

            <div class="actions-row">
                <a class="btn btn-outline-primary" href="/privacy/collected-data">See Collected Data</a>
            </div>
        </section>

        <section class="privacy-card">
            <p class="eyebrow">Your Controls</p>
            <h2>What You Can Review Or Remove</h2>
            <p>
                The collected-data page shows only the analytics currently tied to this browser's visitor identifier. It does not
                expose data collected from anyone else.
            </p>
            <ul class="privacy-list">
                <li>page visits are grouped by page, with individual visit details available on expand</li>
                <li>external link clicks are grouped by platform, with individual click details available on expand</li>
                <li>saved coarse location data can be shown on a map with a shaded 25-mile privacy radius</li>
                <li>you can delete previously collected analytics for this browser without disabling future tracking</li>
                <li>turning off approximate location sharing clears previously saved location-related analytics for this browser</li>
            </ul>
        </section>
    </div>
}

@if (isPreferenceConfirmModalOpen)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Privacy Preference Change</h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="HidePreferenceConfirmModal"></button>
                </div>
                <div class="modal-body">
                    <p>
                        Are you sure you want to turn off <strong>@pendingPreferenceLabel</strong> for this browser?
                    </p>
                    <p class="supporting-copy">
                        @pendingPreferenceDescription
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HidePreferenceConfirmModal">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmPreferenceDisableAsync">Yes, Turn It Off</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-backdrop fade show"></div>
}

@code {
    private const string VisitorCookieName = "axl_visitor_id";
    private bool isLoading = true;
    private PrivacyPreferences preferences = new();
    private string? statusMessage;
    private bool isPreferenceConfirmModalOpen;
    private string pendingPreferenceKey = string.Empty;
    private string pendingPreferenceLabel = string.Empty;
    private string pendingPreferenceDescription = string.Empty;
    private int uniqueVisitorCount;
    private const int MinimumUniqueVisitors = 1000;
    private static readonly DateOnly LastUpdated = new(2026, 3, 21);
    private bool canDisableEssentialMetrics => uniqueVisitorCount >= MinimumUniqueVisitors;

    protected override async Task OnInitializedAsync()
    {
        var analyticsSummary = await AnalyticsService.GetDashboardSummaryAsync();
        uniqueVisitorCount = analyticsSummary.UniqueVisitors;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        preferences = await PrivacyPreferencesService.GetAsync();
        isLoading = false;
        StateHasChanged();
    }

    private async Task PersistPreferencesAsync(string? successMessage = null)
    {
        var result = await PrivacyPreferencesService.SaveAsync(preferences);
        preferences = result.Preferences;
        statusMessage = result.LocationPermissionDenied
            ? "Privacy preferences updated. Approximate location sharing stayed off because browser location permission was denied."
            : successMessage ?? "Privacy preferences updated for this browser.";
    }

    private async Task HandleApproximateLocationChanged(ChangeEventArgs args)
    {
        var newValue = GetCheckboxValue(args);
        if (!newValue)
        {
            ShowPreferenceConfirmModal(
                "approximate-location",
                "Approximate Location Sharing",
                "Turning this off will stop future approximate location collection and remove previously stored location-related analytics for this browser.");
            return;
        }

        var previousValue = preferences.ShareApproximateLocation;
        preferences.ShareApproximateLocation = newValue;

        var result = await PrivacyPreferencesService.SyncApproximateLocationPreferenceAsync(preferences);
        preferences = result.Preferences;

        if (result.LocationPermissionDenied)
        {
            statusMessage = "Approximate location sharing stayed off because browser location permission was denied.";
        }
        else if (previousValue && !preferences.ShareApproximateLocation)
        {
            var visitorId = HttpContextAccessor.HttpContext?.Request.Cookies[VisitorCookieName];
            if (!string.IsNullOrWhiteSpace(visitorId))
            {
                await AnalyticsService.DeleteVisitorLocationDataAsync(visitorId);
            }

            await PersistPreferencesAsync("Approximate location sharing was turned off and previously stored location-related analytics for this browser were removed.");
            return;
        }

        await PersistPreferencesAsync();
    }

    private async Task HandleEssentialMetricsChanged(ChangeEventArgs args)
    {
        var newValue = GetCheckboxValue(args);
        if (!newValue)
        {
            ShowPreferenceConfirmModal(
                "essential-metrics",
                "Essential Site Analytics",
                "Turning this off will stop future essential analytics for this browser and delete existing analytics tied to this visitor id.");
            return;
        }

        preferences.AllowEssentialSiteMetrics = newValue;
        await PersistPreferencesAsync();
    }

    private async Task HandleEnhancedEngagementChanged(ChangeEventArgs args)
    {
        var newValue = GetCheckboxValue(args);
        if (!newValue)
        {
            ShowPreferenceConfirmModal(
                "enhanced-engagement",
                "Enhanced Engagement Metrics",
                "Turning this off will stop future enhanced engagement metrics for this browser.");
            return;
        }

        preferences.AllowEnhancedEngagementMetrics = newValue;
        await PersistPreferencesAsync();
    }

    private async Task HandlePersonalizationChanged(ChangeEventArgs args)
    {
        var newValue = GetCheckboxValue(args);
        if (!newValue)
        {
            ShowPreferenceConfirmModal(
                "personalization",
                "Personalization Metrics",
                "Turning this off will stop future personalization-related metrics for this browser.");
            return;
        }

        preferences.AllowPersonalizationMetrics = newValue;
        await PersistPreferencesAsync();
    }

    private void ShowPreferenceConfirmModal(string preferenceKey, string label, string description)
    {
        pendingPreferenceKey = preferenceKey;
        pendingPreferenceLabel = label;
        pendingPreferenceDescription = description;
        isPreferenceConfirmModalOpen = true;
        StateHasChanged();
    }

    private void HidePreferenceConfirmModal()
    {
        pendingPreferenceKey = string.Empty;
        pendingPreferenceLabel = string.Empty;
        pendingPreferenceDescription = string.Empty;
        isPreferenceConfirmModalOpen = false;
        StateHasChanged();
    }

    private async Task ConfirmPreferenceDisableAsync()
    {
        switch (pendingPreferenceKey)
        {
            case "essential-metrics":
                preferences.AllowEssentialSiteMetrics = false;
                await PersistPreferencesAsync();
                break;
            case "approximate-location":
                preferences.ShareApproximateLocation = false;

                var result = await PrivacyPreferencesService.SyncApproximateLocationPreferenceAsync(preferences);
                preferences = result.Preferences;

                var visitorId = HttpContextAccessor.HttpContext?.Request.Cookies[VisitorCookieName];
                if (!string.IsNullOrWhiteSpace(visitorId))
                {
                    await AnalyticsService.DeleteVisitorLocationDataAsync(visitorId);
                }

                await PersistPreferencesAsync("Approximate location sharing was turned off and previously stored location-related analytics for this browser were removed.");
                break;
            case "enhanced-engagement":
                preferences.AllowEnhancedEngagementMetrics = false;
                await PersistPreferencesAsync();
                break;
            case "personalization":
                preferences.AllowPersonalizationMetrics = false;
                await PersistPreferencesAsync();
                break;
        }

        HidePreferenceConfirmModal();
    }

    private static bool GetCheckboxValue(ChangeEventArgs args)
    {
        return args.Value switch
        {
            bool booleanValue => booleanValue,
            string stringValue when bool.TryParse(stringValue, out var parsedValue) => parsedValue,
            _ => false
        };
    }
}
