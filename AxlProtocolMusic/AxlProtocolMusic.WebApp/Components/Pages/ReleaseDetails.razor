            Tags.RemoveAt(index);
            await InvokeAsync(StateHasChanged);
            await ScheduleAutosave();
        }
    }

    private async Task ScheduleAutosave()
    {
        editorErrorMessage = null;

        if (IsShortDescriptionAutosaveBlocked)
        {
            autosaveCancellationTokenSource?.Cancel();
            autosaveCancellationTokenSource?.Dispose();
            autosaveCancellationTokenSource = null;
            editorStatusMessage = $"Autosave paused. Short description is {ShortDescriptionCharacterCount}/{ShortDescriptionSoftLimit} characters.";
            isEditorStatusWarning = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        var version = Interlocked.Increment(ref autosaveVersion);

        autosaveCancellationTokenSource?.Cancel();
        autosaveCancellationTokenSource?.Dispose();
        autosaveCancellationTokenSource = new CancellationTokenSource();
        var cancellationToken = autosaveCancellationTokenSource.Token;

        try
        {
            await Task.Delay(AutoSaveDelayMilliseconds, cancellationToken);
            await SaveAsync(version, cancellationToken);
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task SaveAsync(long version, CancellationToken cancellationToken)
    {
        if (release is null || version <= Interlocked.Read(ref lastSavedVersion))
        {
            return;
        }

        if (IsShortDescriptionAutosaveBlocked)
        {
            editorStatusMessage = $"Autosave paused. Short description is {ShortDescriptionCharacterCount}/{ShortDescriptionSoftLimit} characters.";
            isEditorStatusWarning = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        await saveSemaphore.WaitAsync(cancellationToken);
        try
        {
            if (release is null || version <= lastSavedVersion)
            {
                return;
            }

            editorStatusMessage = "Saving changes...";
            isEditorStatusWarning = false;
            await InvokeAsync(StateHasChanged);

            var request = BuildUpdateRequest();
            var validationResults = new List<System.ComponentModel.DataAnnotations.ValidationResult>();
            if (!System.ComponentModel.DataAnnotations.Validator.TryValidateObject(
                    request,
                    new System.ComponentModel.DataAnnotations.ValidationContext(request),
                    validationResults,
                    validateAllProperties: true))
            {
                editorErrorMessage = validationResults
                    .Select(result => result.ErrorMessage)
                    .FirstOrDefault(message => !string.IsNullOrWhiteSpace(message))
                    ?? "Complete all required release fields.";
                editorStatusMessage = null;
                await InvokeAsync(StateHasChanged);
                return;
            }

            var previousSlug = release.Slug;
            var previousCoverImageUrl = release.CoverImageUrl;
            var result = await ReleaseService.UpdateReleaseAsync(request, cancellationToken);

            if (!result.Succeeded)
            {
                editorErrorMessage = result.ErrorMessage;
                editorStatusMessage = null;
                await InvokeAsync(StateHasChanged);
                return;
            }

            editableRelease.OriginalSlug = result.Slug;
            release = BuildReleaseViewModel(result.Slug);
            savedShortDescription = editableRelease.ShortDescription ?? string.Empty;
            lastSavedVersion = version;
            editorStatusMessage = "All changes saved.";
            editorErrorMessage = null;
            isEditorStatusWarning = false;

            if (!string.Equals(previousSlug, result.Slug, StringComparison.OrdinalIgnoreCase))
            {
                NavigationManager.NavigateTo($"/releases/{Uri.EscapeDataString(result.Slug)}", replace: true);
            }

            if (!string.IsNullOrWhiteSpace(previousCoverImageUrl)
                && ReleaseService.IsManagedImageUrl(previousCoverImageUrl)
                && !string.Equals(previousCoverImageUrl, editableRelease.CoverImageUrl, StringComparison.OrdinalIgnoreCase))
            {
                await ImageStorageService.DeleteAsync(previousCoverImageUrl, cancellationToken);
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception exception)
        {
            editorErrorMessage = exception.Message;
            editorStatusMessage = null;
            isEditorStatusWarning = false;
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            saveSemaphore.Release();
        }
    }

    private async Task HandleCoverImageSelectedAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null || release is null)
        {
            return;
        }

        editorErrorMessage = null;
        editorStatusMessage = "Uploading cover image...";
        await InvokeAsync(StateHasChanged);

        try
        {
            await using var readStream = file.OpenReadStream(5 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await readStream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            var formFile = new Microsoft.AspNetCore.Http.FormFile(memoryStream, 0, memoryStream.Length, file.Name, file.Name)
            {
                Headers = new Microsoft.AspNetCore.Http.HeaderDictionary(),
                ContentType = file.ContentType
            };

            var imageSaveResult = await ImageStorageService.SaveReleaseImageAsync(formFile);
            editableRelease.CoverImageUrl = imageSaveResult.Url;
            await SaveAsync(Interlocked.Increment(ref autosaveVersion), CancellationToken.None);
        }
        catch (Exception exception)
        {
            editorErrorMessage = exception.Message;
            editorStatusMessage = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private ReleaseUpdateRequest BuildUpdateRequest()
    {
        editableRelease.ShortDescription = HasShortDescriptionChangedFromSaved
            ? editableRelease.ShortDescription ?? string.Empty
            : savedShortDescription;
        editableRelease.Credits = Credits
            .Select(credit => new ReleaseCredit
            {
                Name = credit.Name,
                Roles = credit.Roles.ToList()
            })
            .ToList();
        editableRelease.Tracks = Tracks
            .Select(track => new ReleaseTrack
            {
                Title = track.Title,
                Duration = track.Duration,
                Lyrics = track.Lyrics
            })
            .ToList();
        editableRelease.Links = Links
            .Select(link => new ReleaseLink
            {
                PlatformName = link.PlatformName,
                Url = link.Url
            })
            .ToList();
        editableRelease.Tags = Tags.ToList();
        return editableRelease;
    }

    private ReleaseDetailsViewModel BuildReleaseViewModel(string slug)
    {
        return new ReleaseDetailsViewModel
        {
            Id = release?.Id ?? string.Empty,
            Title = editableRelease.Title,
            Slug = slug,
            ShortDescription = editableRelease.ShortDescription,
            CoverImageUrl = editableRelease.CoverImageUrl?.Trim() ?? string.Empty,
            Story = editableRelease.Story?.Trim() ?? string.Empty,
            Credits = Credits
                .Select(credit => new ReleaseCredit
                {
                    Name = credit.Name.Trim(),
                    Roles = credit.Roles
                        .Select(role => role.Trim())
                        .Where(role => !string.IsNullOrWhiteSpace(role))
                        .ToList()
                })
                .Where(credit => !string.IsNullOrWhiteSpace(credit.Name) || credit.Roles.Count > 0)
                .ToList(),
            Tracks = Tracks
                .Select(track => new ReleaseTrack
                {
                    Title = track.Title.Trim(),
                    Duration = track.Duration.Trim(),
                    Lyrics = track.Lyrics.Trim()
                })
                .Where(track =>
                    !string.IsNullOrWhiteSpace(track.Title)
                    || !string.IsNullOrWhiteSpace(track.Duration)
                    || !string.IsNullOrWhiteSpace(track.Lyrics))
                .ToList(),
            Links = Links
                .Select(link => new ReleaseLink
                {
                    PlatformName = link.PlatformName.Trim(),
                    Url = link.Url.Trim()
                })
                .Where(link => !string.IsNullOrWhiteSpace(link.PlatformName) || !string.IsNullOrWhiteSpace(link.Url))
                .ToList(),
            ReleaseType = GetDisplayReleaseType(Tracks.Count, editableRelease.ReleaseTypeOverride),
            ReleaseTypeOverride = editableRelease.ReleaseTypeOverride?.Trim() ?? string.Empty,
            Tags = Tags
                .Select(tag => tag.Trim())
                .Where(tag => !string.IsNullOrWhiteSpace(tag))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList(),
            ReleaseDateUtc = new DateTimeOffset(DateTime.SpecifyKind(editableRelease.ReleaseDate.Date, DateTimeKind.Utc)),
            IsPublished = editableRelease.IsPublished
        };
    }

    private static string GetDisplayReleaseType(int trackCount, string? releaseTypeOverride)
    {
        if (!string.IsNullOrWhiteSpace(releaseTypeOverride))
        {
            return releaseTypeOverride;
        }

        return trackCount switch
        {
            <= 1 => "Single",
            <= 6 => "EP",
            _ => "Album"
        };
    }

    private static string FormatTotalPlayTime(IEnumerable<ReleaseTrack> tracks)
    {
        var totalSeconds = tracks
            .Select(track => TryParseDuration(track.Duration))
            .Where(seconds => seconds.HasValue)
            .Sum(seconds => seconds!.Value);

        if (totalSeconds <= 0)
        {
            return string.Empty;
        }

        var timeSpan = TimeSpan.FromSeconds(totalSeconds);
        return timeSpan.TotalHours >= 1
            ? $"{(int)timeSpan.TotalHours}:{timeSpan.Minutes:D2}:{timeSpan.Seconds:D2}"
            : $"{timeSpan.Minutes}:{timeSpan.Seconds:D2}";
    }

    private static string NormalizeTrackDurationInput(string? value)
    {
        var normalized = value?.Trim() ?? string.Empty;
        if (string.IsNullOrEmpty(normalized))
        {
            return string.Empty;
        }

        if (normalized.All(char.IsDigit))
        {
            return normalized.Length switch
            {
                3 => $"{normalized[..1]}:{normalized[1..]}",
                4 => $"{normalized[..2]}:{normalized[2..]}",
                _ => normalized
            };
        }

        var colonCount = normalized.Count(character => character == ':');
        if (colonCount <= 1 && normalized.Where(character => character != ':').All(char.IsDigit))
        {
            var digitsOnly = new string(normalized.Where(char.IsDigit).ToArray());
            return digitsOnly.Length switch
            {
                3 => $"{digitsOnly[..1]}:{digitsOnly[1..]}",
                4 => $"{digitsOnly[..2]}:{digitsOnly[2..]}",
                _ => normalized
            };
        }

        return normalized;
    }

    private static int? TryParseDuration(string? duration)
    {
        if (string.IsNullOrWhiteSpace(duration))
        {
            return null;
        }

        var parts = duration
            .Trim()
            .Split(':', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length == 2
            && int.TryParse(parts[0], out var minutes)
            && int.TryParse(parts[1], out var seconds)
            && minutes >= 0
            && seconds is >= 0 and < 60)
        {
            return (minutes * 60) + seconds;
        }

        if (parts.Length == 3
            && int.TryParse(parts[0], out var hours)
            && int.TryParse(parts[1], out var remainingMinutes)
            && int.TryParse(parts[2], out var remainingSeconds)
            && hours >= 0
            && remainingMinutes is >= 0 and < 60
            && remainingSeconds is >= 0 and < 60)
        {
            return (hours * 3600) + (remainingMinutes * 60) + remainingSeconds;
        }

        return null;
    }

    private string GetTrackLabel(int index)
    {
        if (index < 0 || index >= Tracks.Count)
        {
            return "track";
        }

        return string.IsNullOrWhiteSpace(Tracks[index].Title)
            ? $"track {index + 1}"
            : Tracks[index].Title.Trim();
    }

    private static string GetReleaseArtworkUrl(string? coverImageUrl)
        => string.IsNullOrWhiteSpace(coverImageUrl)
            ? PlaceholderAlbumArtPath
            : coverImageUrl;

    private static bool IsUpcomingRelease(DateTimeOffset releaseDateUtc)
        => releaseDateUtc > DateTimeOffset.UtcNow;

