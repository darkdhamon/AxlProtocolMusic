    }

    private async Task HandleTrackDurationInputAsync(int index, string? value)
    {
        if (index < 0 || index >= Tracks.Count)
        {
            return;
        }

        Tracks[index].Duration = NormalizeTrackDurationInput(value);
        await ScheduleAutosave();
    }

    private async Task SaveTrackLyricsAsync(int index)
    {
        if (index < 0 || index >= Tracks.Count)
        {
            return;
        }

        autosaveCancellationTokenSource?.Cancel();
        autosaveCancellationTokenSource?.Dispose();
        autosaveCancellationTokenSource = null;

        editorErrorMessage = null;
        editorStatusMessage = $"Saving lyrics for {GetTrackLabel(index)}...";
        await InvokeAsync(StateHasChanged);

        await SaveAsync(Interlocked.Increment(ref autosaveVersion), CancellationToken.None);

        if (string.IsNullOrWhiteSpace(editorErrorMessage))
        {
            editorStatusMessage = $"Lyrics saved for {GetTrackLabel(index)}.";
            await InvokeAsync(StateHasChanged);
        }
    }

