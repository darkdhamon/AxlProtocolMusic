@page "/releases/{Slug}"
@rendermode InteractiveServer
@using AxlProtocolMusic.WebApp.Services.ServiceModels
@inject IReleaseService ReleaseService
@inject IImageStorageService ImageStorageService
@inject IOptions<EditorSettings> EditorSettings
@inject NavigationManager NavigationManager
@implements IDisposable

@if (isLoading)
{
    <PageTitle>Release Details</PageTitle>
    <p><em>Loading release details...</em></p>
}
else if (release is null)
{
    <PageTitle>Release Not Found</PageTitle>
    <h1>Release Not Found</h1>
    <p>The release you requested could not be found.</p>
    <a class="btn btn-outline-primary" href="/releases">Back to Releases</a>
}
else
{
    <PageTitle>@($"{release.Title} | Release Details")</PageTitle>
    <div class="release-details-page">
        <div class="@(isAdminUser ? "release-details-layout release-details-layout-with-sidebar" : "release-details-layout")">
            <div class="release-details-content">
        <div class="release-page-header">
            <a class="back-link" href="/releases">Back To Releases</a>
            <AuthorizeView Roles="Admin">
                <Authorized>
                    <button class="btn btn-outline-light btn-sm" type="button" @onclick="ShowDeleteModal">
                        Delete Release
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <div class="alert alert-danger" role="alert">@Error</div>
        }

        @if (!string.IsNullOrWhiteSpace(Success))
        {
            <div class="alert alert-success" role="alert">@Success</div>
        }

        <section class="release-hero">
            <div class="release-hero-copy">
                <h1>@release.Title</h1>
                <p class="release-date">@release.ReleaseDateUtc.ToLocalTime().ToString("MMMM d, yyyy")</p>
                @if (IsUpcomingRelease(release.ReleaseDateUtc))
                {
                    <div class="release-hero-badges">
                        <span class="tag-chip upcoming-release-chip">Upcoming Release</span>
                    </div>
                }
                <p class="release-summary">@release.ShortDescription</p>

                @if (release.Tags.Count > 0)
                {
                    <div class="tag-list">
                        @foreach (var tag in release.Tags)
                        {
                            <span class="tag-chip">@tag</span>
                        }
                    </div>
                }

                <section class="release-meta-panel">
                    <h2>Release Info</h2>

                    <p class="release-type-line"><strong>Type:</strong> @release.ReleaseType</p>
                    @if (!string.IsNullOrWhiteSpace(TotalPlayTimeDisplay))
                    {
                        <p class="release-type-line"><strong>Total Play Time:</strong> @TotalPlayTimeDisplay</p>
                    }

                    @if (release.Credits.Count > 0)
                    {
                        <ul class="credits-list credits-list-inline">
                            @foreach (var credit in release.Credits)
                            {
                                <li>
                                    <span class="credit-name">@credit.Name</span>
                                    @if (credit.Roles.Count > 0)
                                    {
                                        <span class="credit-role">@string.Join(", ", credit.Roles)</span>
                                    }
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="release-meta-empty-state">Credits have not been added yet.</p>
                    }
                </section>
            </div>

            <div class="release-hero-artwork">
                <img
                    src="@GetReleaseArtworkUrl(release.CoverImageUrl)"
                    alt="@release.Title cover art"
                    onerror="this.onerror=null;this.src='/Assets/Misc/Placeholder-AlbumArt.png';" />
            </div>
        </section>

        @if (release.Links.Count > 0)
        {
            <section class="release-links-panel">
                <h2>Listen And Buy</h2>
                <div class="release-links-list">
                    @foreach (var link in release.Links)
                    {
                        <a class="release-link-button" href="@link.Url" target="_blank" rel="noopener noreferrer">@link.PlatformName</a>
                    }
                </div>
            </section>
        }

        <section class="release-content-grid">
            <section class="release-content-card">
                <h2>Story Behind The Release</h2>
                @if (!string.IsNullOrWhiteSpace(release.Story))
                {
                    <MarkdownRenderer Content="@release.Story" CssClass="release-rich-text markdown-content" />
                }
                else
                {
                    <p class="content-empty-state">The story behind this release will appear here.</p>
                }
            </section>

            <section class="release-content-card">
                <h2>Tracks And Lyrics</h2>
                @if (release.Tracks.Count > 0)
                {
                    <ol class="track-list track-list-detailed">
                        @foreach (var track in release.Tracks.Select((item, index) => new { item, index }))
                        {
                            <li>
                                <div class="track-copy">
                                    <span class="track-title">@track.item.Title</span>
                                    @if (!string.IsNullOrWhiteSpace(track.item.Duration))
                                    {
                                        <span class="track-duration">@track.item.Duration</span>
                                    }
                                </div>
                                <button
                                    class="btn btn-outline-primary btn-sm"
                                    type="button"
                                    @onclick="() => ShowLyricsModal(track.item)"
                                    disabled="@string.IsNullOrWhiteSpace(track.item.Lyrics)">
                                    See Lyrics
                                </button>
                            </li>
                        }
                    </ol>
                }
                else
                {
                    <p class="content-empty-state">Track details and lyrics have not been published for this release yet.</p>
                }
            </section>
        </section>
            </div>

        <AuthorizeView Roles="Admin">
            <Authorized>
                <aside class="admin-edit-panel admin-edit-sidebar">
                    <div class="admin-edit-header">
                        <p class="eyebrow">Admin</p>
                        <h2>Edit Release Details</h2>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(editorErrorMessage))
                    {
                        <div class="alert alert-danger" role="alert">@editorErrorMessage</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(editorStatusMessage))
                    {
                        <div class="alert @(isEditorStatusWarning ? "alert-warning" : "alert-success")" role="alert">@editorStatusMessage</div>
                    }

                    <div class="admin-edit-form">
                        <div class="form-grid">
                            <div>
                                <label class="form-label" for="title">Title</label>
                                <input class="form-control" id="title" @bind="editableRelease.Title" @bind:event="oninput" @bind:after="ScheduleAutosave" required />
                            </div>

                            <div>
                                <label class="form-label" for="slug">Slug</label>
                                <input class="form-control" id="slug" @bind="editableRelease.Slug" @bind:event="oninput" @bind:after="ScheduleAutosave" required />
                            </div>

                            <div>
                                <label class="form-label" for="releaseDate">Release Date</label>
                                <input
                                    class="form-control"
                                    id="releaseDate"
                                    type="date"
                                    @bind="editableRelease.ReleaseDate"
                                    @bind:format="yyyy-MM-dd"
                                    @bind:after="ScheduleAutosave"
                                    required />
                            </div>

                            <div>
                                <label class="form-label" for="coverImageUrl">Cover Image Url</label>
                                <input
                                    class="form-control"
                                    id="coverImageUrl"
                                    @bind="editableRelease.CoverImageUrl"
                                    @bind:event="oninput"
                                    @bind:after="ScheduleAutosave" />
                                <div class="form-text">Paste an external image URL or upload a new image file below.</div>
                            </div>

                            <div>
                                <label class="form-label" for="coverImageFile">Upload Cover Image</label>
                                <InputFile
                                    id="coverImageFile"
                                    class="form-control"
                                    OnChange="HandleCoverImageSelectedAsync"
                                    accept=".jpg,.jpeg,.png,.webp,.gif,image/jpeg,image/png,image/webp,image/gif" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="shortDescription">Short Description</label>
                            <textarea
                                class="form-control"
                                id="shortDescription"
                                @bind="editableRelease.ShortDescription"
                                @bind:event="oninput"
                                @bind:after="ScheduleAutosave"
                                rows="4"
                                required></textarea>
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-1">
                                <div class="form-text @(IsShortDescriptionAutosaveBlocked ? "text-danger" : string.Empty)">
                                    @ShortDescriptionCharacterCount/@ShortDescriptionSoftLimit characters
                                </div>
                                @if (IsShortDescriptionAutosaveBlocked)
                                {
                                    <div class="form-text text-danger">Autosave is paused until the short description is 350 characters or fewer.</div>
                                }
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="story">Story Behind The Release</label>
                            <MarkdownEditor
                                Id="story"
                                Rows="10"
                                EditorClass="form-control"
                                @bind-Value="editableRelease.Story"
                                @bind-Value:after="ScheduleAutosave" />
                        </div>

            <div class="dynamic-panel mb-3">
                <div class="dynamic-panel-header">
                    <div>
                        <label class="form-label">Credits</label>
                        <div class="form-text">Add one person, then assign multiple roles as needed.</div>
                    </div>

                    <button class="btn btn-outline-primary btn-sm" type="button" @onclick="AddCredit">Add Credit</button>
                </div>

                            @if (Credits.Count == 0)
                            {
                                <p class="dynamic-panel-empty">No credits added yet.</p>
                            }
                            else
                            {
                    @for (var index = 0; index < Credits.Count; index++)
                    {
                        var currentIndex = index;
                        var credit = Credits[index];

                        <div class="dynamic-row">
                                        <div class="dynamic-row-grid">
                                            <div>
                                                <label class="form-label" for="@($"credit-name-{index}")">Name</label>
                                                <input
                                                    class="form-control"
                                                    id="@($"credit-name-{index}")"
                                                    list="known-contributor-names"
                                                    @bind="credit.Name"
                                                    @bind:event="oninput"
                                                    @bind:after="() => HandleCreditNameChangedAsync(credit)" />
                                </div>

                                <div>
                                    <label class="form-label" for="@($"credit-role-input-{index}")">Roles</label>
                                    <div class="role-entry-row">
                                        <input
                                            class="form-control"
                                            id="@($"credit-role-input-{index}")"
                                            list="known-credit-roles"
                                            @bind="credit.RoleInput"
                                            @bind:event="oninput"
                                            @onkeydown="args => HandleCreditRoleKeyDownAsync(credit, args)" />
                                        <button class="btn btn-outline-primary btn-sm" type="button" @onclick="() => AddRoleToCreditAsync(credit)">Add Role</button>
                                    </div>
                                    <div class="role-chip-list">
                                        @for (var roleIndex = 0; roleIndex < credit.Roles.Count; roleIndex++)
                                        {
                                            var currentRoleIndex = roleIndex;
                                            <button class="role-chip-edit" type="button" @onclick="() => RemoveRoleFromCredit(credit, currentRoleIndex)">@credit.Roles[currentRoleIndex] x</button>
                                        }
                                    </div>
                                </div>
                            </div>

                            <button class="btn btn-outline-danger btn-sm" type="button" @onclick="() => RemoveCredit(currentIndex)">Remove</button>
                        </div>
                    }
                }
            </div>

            <div class="dynamic-panel mb-3">
                <div class="dynamic-panel-header">
                    <div>
                        <label class="form-label">Tracks</label>
                        <div class="form-text">Track count determines Single, EP, or Album unless you set an override.</div>
                    </div>

                    <button class="btn btn-outline-primary btn-sm" type="button" @onclick="AddTrack">Add Track</button>
                </div>

                <div class="release-type-summary">
                    <span>Computed type: <strong>@ComputedReleaseType</strong></span>
                </div>

                <div>
                    <label class="form-label" for="releaseTypeOverride">Release Type Override</label>
                    <select class="form-select" id="releaseTypeOverride" @bind="editableRelease.ReleaseTypeOverride" @bind:after="ScheduleAutosave">
                        <option value="">Auto</option>
                        <option value="Single">Single</option>
                        <option value="EP">EP</option>
                        <option value="Album">Album</option>
                    </select>
                </div>

                @if (Tracks.Count == 0)
                {
                    <p class="dynamic-panel-empty">No tracks added yet. With zero or one track, the release is treated as a single.</p>
                }
                else
                {
                    @for (var index = 0; index < Tracks.Count; index++)
                    {
                        var currentIndex = index;
                        var track = Tracks[index];

                        <div class="dynamic-row">
                            <div class="track-row-grid">
                                <div class="track-number-chip">Track @(index + 1)</div>
                                <div>
                                    <label class="form-label" for="@($"track-title-{index}")">Title</label>
                                    <input
                                        class="form-control"
                                        id="@($"track-title-{index}")"
                                        @bind="track.Title"
                                        @bind:event="oninput"
                                        @bind:after="ScheduleAutosave" />
                                </div>
                                <div>
                                    <label class="form-label" for="@($"track-duration-{index}")">Duration</label>
                                    <input
                                        class="form-control"
                                        id="@($"track-duration-{index}")"
                                        value="@track.Duration"
                                        placeholder="0:00"
                                        @oninput="args => HandleTrackDurationInputAsync(currentIndex, args.Value?.ToString())" />
                                </div>
                            </div>

                            <div>
                                <label class="form-label" for="@($"track-lyrics-{index}")">Lyrics</label>
                                <MarkdownEditor
                                    Id="@($"track-lyrics-{index}")"
                                    Rows="8"
                                    EditorClass="form-control lyrics-editor"
                                    UseLyricsPreviewStyle="true"
                                    @bind-Value="track.Lyrics" />
                                <div class="track-lyrics-actions">
                                    <button class="btn btn-primary btn-sm" type="button" @onclick="() => SaveTrackLyricsAsync(currentIndex)">Save Lyrics</button>
                                </div>
                            </div>

                            <button class="btn btn-outline-danger btn-sm" type="button" @onclick="() => RemoveTrack(currentIndex)">Remove</button>
                        </div>
                    }
                }
            </div>

            <div class="dynamic-panel mb-3">
                <div class="dynamic-panel-header">
                    <div>
                        <label class="form-label">Streaming And Store Links</label>
                        <div class="form-text">Add direct destinations for listening, streaming, or buying.</div>
                    </div>

                    <button class="btn btn-outline-primary btn-sm" type="button" @onclick="AddLink">Add Link</button>
                </div>

                @if (Links.Count == 0)
                {
                    <p class="dynamic-panel-empty">No release links added yet.</p>
                }
                else
                {
                    @for (var index = 0; index < Links.Count; index++)
                    {
                        var currentIndex = index;
                        var link = Links[index];

                        <div class="dynamic-row">
                            <div class="dynamic-row-grid">
                                <div>
                                    <label class="form-label" for="@($"link-platform-{index}")">Platform</label>
                                    <input
                                        class="form-control"
                                        id="@($"link-platform-{index}")"
                                        list="known-release-platforms"
                                        @bind="link.PlatformName"
                                        @bind:event="oninput"
                                        @bind:after="ScheduleAutosave" />
                                </div>

                                <div>
                                    <label class="form-label" for="@($"link-url-{index}")">URL</label>
                                    <input
                                        class="form-control"
                                        id="@($"link-url-{index}")"
                                        @bind="link.Url"
                                        @bind:event="oninput"
                                        @bind:after="ScheduleAutosave" />
                                </div>
                            </div>

                            <button class="btn btn-outline-danger btn-sm" type="button" @onclick="() => RemoveLink(currentIndex)">Remove</button>
                        </div>
                    }
                }
            </div>

                        <div class="dynamic-panel mb-3">
                            <div class="dynamic-panel-header">
                                <div>
                                    <label class="form-label">Tags</label>
                                    <div class="form-text">Add tags to group themes, styles, or eras.</div>
                                </div>

                                <button class="btn btn-outline-primary btn-sm" type="button" @onclick="AddTagFromInput">Add Tag</button>
                            </div>

                            <div>
                                <label class="form-label" for="tag-input">Tag</label>
                                <div class="role-entry-row">
                                    <input
                                        class="form-control"
                                        id="tag-input"
                                        list="known-tags"
                                        @bind="TagInput"
                                        @bind:event="oninput"
                                        @onkeydown="HandleTagInputKeyDownAsync" />
                                    <button class="btn btn-outline-primary btn-sm" type="button" @onclick="AddTagFromInput">Add Tag</button>
                                </div>
                            </div>

                            <div class="role-chip-list">
                                @for (var index = 0; index < Tags.Count; index++)
                                {
                                    var currentIndex = index;
                                    <button class="role-chip-edit" type="button" @onclick="() => RemoveTag(currentIndex)">@Tags[currentIndex] x</button>
                                }
                            </div>

                            @if (Tags.Count == 0)
                            {
                                <p class="dynamic-panel-empty">No tags added yet.</p>
                            }
                        </div>

                        <div class="form-check mb-3">
                            <input
                                class="form-check-input"
                                id="isPublished"
                                type="checkbox"
                                @bind="editableRelease.IsPublished"
                                @bind:after="ScheduleAutosave" />
                            <label class="form-check-label" for="isPublished">Published</label>
                        </div>
                    </div>

                    <datalist id="known-credit-roles">
                        @foreach (var role in KnownCreditRoles)
                        {
                            <option value="@role"></option>
                        }
                    </datalist>

                    <datalist id="known-release-platforms">
                        @foreach (var platform in KnownPlatforms)
                        {
                            <option value="@platform"></option>
                        }
                    </datalist>

                    <datalist id="known-contributor-names">
                        @foreach (var contributorName in KnownContributorNames)
                        {
                            <option value="@contributorName"></option>
                        }
                    </datalist>

                    <datalist id="known-tags">
                        @foreach (var tag in KnownTags)
                        {
                            <option value="@tag"></option>
                        }
                    </datalist>
                </aside>
            </Authorized>
        </AuthorizeView>
        </div>
    </div>
}

@if (isLyricsModalOpen && selectedLyricsTrack is not null)
{
    <div class="lyrics-modal-overlay" tabindex="-1" role="dialog" aria-modal="true" @onclick="HideLyricsModal">
        <div class="lyrics-modal-dialog" role="document" @onclick:stopPropagation="true">
            <div class="lyrics-modal-surface">
                <div class="lyrics-modal-header">
                    <h5 class="lyrics-modal-title">@selectedLyricsTrack.Title Lyrics</h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="HideLyricsModal"></button>
                </div>
                <div class="lyrics-modal-body">
                    <MarkdownRenderer Content="@selectedLyricsTrack.Lyrics" CssClass="lyrics-block markdown-content modal-lyrics-block song-lyrics-markdown" />
                </div>
            </div>
        </div>
    </div>
}

@if (isDeleteModalOpen && release is not null)
{
    <div class="lyrics-modal-overlay" tabindex="-1" role="dialog" aria-modal="true" @onclick="HideDeleteModal">
        <div class="lyrics-modal-dialog" role="document" @onclick:stopPropagation="true">
            <div class="lyrics-modal-surface delete-confirm-surface">
                <div class="lyrics-modal-header">
                    <h5 class="lyrics-modal-title">Delete Release</h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="HideDeleteModal"></button>
                </div>
                <div class="delete-confirm-body">
                    <p>Are you sure you want to delete <strong>@release.Title</strong>?</p>
                    <p>This removes the release from the catalog and cannot be undone from this page.</p>
                </div>
                <div class="delete-confirm-actions">
                    <button class="btn btn-outline-secondary" type="button" @onclick="HideDeleteModal" disabled="@isDeletingRelease">Cancel</button>
                    <button class="btn btn-danger" type="button" @onclick="DeleteReleaseAsync" disabled="@isDeletingRelease">
                        @(isDeletingRelease ? "Deleting..." : "Delete Release")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private const int ShortDescriptionSoftLimit = 350;
    private const string PlaceholderAlbumArtPath = "/Assets/Misc/Placeholder-AlbumArt.png";
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    [SupplyParameterFromQuery]
    public string? Success { get; set; }

    private ReleaseDetailsViewModel? release;
    private ReleaseUpdateRequest editableRelease = new();
    private bool isLoading = true;
    private bool isAdminUser;
    private string? editorStatusMessage;
    private string? editorErrorMessage;
    private bool isEditorStatusWarning;
    private bool isLyricsModalOpen;
    private bool isDeleteModalOpen;
    private bool isDeletingRelease;
    private ReleaseTrack? selectedLyricsTrack;
    private CancellationTokenSource? autosaveCancellationTokenSource;
    private long autosaveVersion;
    private long lastSavedVersion;
    private string savedShortDescription = string.Empty;
    private int AutoSaveDelayMilliseconds => EditorSettings.Value.NormalizedAutosaveDelayMilliseconds;
    private readonly SemaphoreSlim saveSemaphore = new(1, 1);
    private List<EditableCredit> Credits { get; set; } = [];
    private List<ReleaseTrack> Tracks { get; set; } = [];
    private List<ReleaseLink> Links { get; set; } = [];
    private List<string> Tags { get; set; } = [];
    private IReadOnlyList<string> KnownCreditRoles { get; set; } = [];
    private IReadOnlyList<string> KnownContributorNames { get; set; } = [];
    private IReadOnlyDictionary<string, IReadOnlyList<string>> KnownContributorRolesByName { get; set; }
        = new Dictionary<string, IReadOnlyList<string>>(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyList<string> KnownTags { get; set; } = [];
    private static readonly IReadOnlyList<string> KnownPlatforms =
    [
        "Spotify",
        "Apple Music",
        "YouTube Music",
        "Amazon Music",
        "Bandcamp",
        "iTunes",
        "SoundCloud",
        "Tidal"
    ];

    private string ComputedReleaseType => GetDisplayReleaseType(Tracks.Count, editableRelease.ReleaseTypeOverride);
    private string TotalPlayTimeDisplay => FormatTotalPlayTime(release?.Tracks ?? []);
    private int ShortDescriptionCharacterCount => editableRelease.ShortDescription?.Length ?? 0;
    private bool HasShortDescriptionChangedFromSaved => !string.Equals(
        editableRelease.ShortDescription ?? string.Empty,
        savedShortDescription,
        StringComparison.Ordinal);
    private bool IsShortDescriptionAutosaveBlocked => ShortDescriptionCharacterCount > ShortDescriptionSoftLimit
        && HasShortDescriptionChangedFromSaved;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        KnownCreditRoles = await ReleaseService.GetKnownCreditRolesAsync();
        KnownContributorNames = await ReleaseService.GetKnownContributorNamesAsync();
        KnownContributorRolesByName = await ReleaseService.GetKnownContributorRolesByNameAsync();
        KnownTags = await ReleaseService.GetKnownTagsAsync();
        var authenticationState = AuthenticationStateTask is null
            ? null
            : await AuthenticationStateTask;

        isAdminUser = authenticationState?.User.IsInRole("Admin") == true;
        var includeUnpublished = isAdminUser;
        release = await ReleaseService.GetReleaseBySlugAsync(Slug, includeUnpublished);
        SyncEditableState();
        isLoading = false;
    }

    private void SyncEditableState()
    {
        if (release is null)
        {
            editableRelease = new ReleaseUpdateRequest();
            Credits = [];
            Tracks = [];
            Links = [];
            Tags = [];
            return;
        }

        editableRelease = new ReleaseUpdateRequest
        {
            OriginalSlug = release.Slug,
            Title = release.Title,
            Slug = release.Slug,
            ShortDescription = release.ShortDescription,
            CoverImageUrl = release.CoverImageUrl,
            Story = release.Story,
            ReleaseTypeOverride = release.ReleaseTypeOverride,
            ReleaseDate = release.ReleaseDateUtc.Date,
            IsPublished = release.IsPublished
        };
        Credits = release.Credits
            .Select(credit => new ReleaseCredit
            {
                Name = credit.Name,
                Roles = credit.Roles.ToList()
            })
            .Select(credit => new EditableCredit
            {
                Name = credit.Name,
                Roles = credit.Roles.ToList()
            })
            .ToList();
        Tracks = release.Tracks
            .Select(track => new ReleaseTrack
            {
                Title = track.Title,
                Duration = track.Duration,
                Lyrics = track.Lyrics
            })
            .ToList();
        Links = release.Links
            .Select(link => new ReleaseLink
            {
                PlatformName = link.PlatformName,
                Url = link.Url
            })
            .ToList();
        Tags = release.Tags.ToList();
        savedShortDescription = release.ShortDescription;
        editorStatusMessage = null;
        editorErrorMessage = null;
        isEditorStatusWarning = false;
        autosaveVersion = 0;
        lastSavedVersion = 0;
    }

    private void AddCredit()
    {
        Credits.Add(new EditableCredit());
        _ = ScheduleAutosave();
    }

    private void RemoveCredit(int index)
    {
        if (index >= 0 && index < Credits.Count)
        {
            Credits.RemoveAt(index);
            _ = ScheduleAutosave();
        }
    }

    private async Task AddRoleToCreditAsync(EditableCredit credit)
    {
        var role = credit.RoleInput.Trim();
        if (string.IsNullOrWhiteSpace(role))
        {
            return;
        }

        if (!credit.Roles.Contains(role, StringComparer.OrdinalIgnoreCase))
        {
            credit.Roles.Add(role);
            await ScheduleAutosave();
        }

        credit.RoleInput = string.Empty;
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleCreditNameChangedAsync(EditableCredit credit)
    {
        var normalizedName = credit.Name.Trim();
        if (string.IsNullOrWhiteSpace(normalizedName))
        {
            await ScheduleAutosave();
            return;
        }

        if (KnownContributorRolesByName.TryGetValue(normalizedName, out var knownRoles) && knownRoles.Count > 0)
        {
            credit.Roles = knownRoles.ToList();
        }

        await ScheduleAutosave();
    }

    private async Task HandleCreditRoleKeyDownAsync(EditableCredit credit, KeyboardEventArgs args)
    {
        if (!string.Equals(args.Key, "Enter", StringComparison.Ordinal))
        {
            return;
        }

        await AddRoleToCreditAsync(credit);
    }

    private void RemoveRoleFromCredit(EditableCredit credit, int roleIndex)
    {
        if (roleIndex >= 0 && roleIndex < credit.Roles.Count)
        {
            credit.Roles.RemoveAt(roleIndex);
            _ = ScheduleAutosave();
        }
    }

    private void AddTrack()
    {
        editableRelease.ReleaseTypeOverride = string.Empty;
        Tracks.Add(new ReleaseTrack());
        _ = ScheduleAutosave();
    }

    private void RemoveTrack(int index)
    {
