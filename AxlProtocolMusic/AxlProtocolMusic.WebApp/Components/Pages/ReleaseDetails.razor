    private void ShowDeleteModal()
    {
        isDeleteModalOpen = true;
    }

    private void HideDeleteModal()
    {
        if (isDeletingRelease)
        {
            return;
        }

        isDeleteModalOpen = false;
    }

    private async Task DeleteReleaseAsync()
    {
        if (release is null || isDeletingRelease)
        {
            return;
        }

        isDeletingRelease = true;
        editorErrorMessage = null;
        editorStatusMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var result = await ReleaseService.DeleteReleaseAsync(release.Slug);

            if (!result.Succeeded)
            {
                editorErrorMessage = result.ErrorMessage;
                isDeleteModalOpen = false;
                return;
            }

            if (!string.IsNullOrWhiteSpace(result.ImageStoragePath)
                && ReleaseService.IsManagedImageUrl(result.ImageStoragePath))
            {
                await ImageStorageService.DeleteAsync(result.ImageStoragePath);
            }

            NavigationManager.NavigateTo("/releases?success=Release%20deleted.", forceLoad: true);
        }
        catch (Exception exception)
        {
            editorErrorMessage = exception.Message;
            isDeleteModalOpen = false;
        }
        finally
        {
            isDeletingRelease = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private sealed class EditableCredit
    {
        public string Name { get; set; } = string.Empty;

        public List<string> Roles { get; set; } = [];

        public string RoleInput { get; set; } = string.Empty;
    }

    private string TagInput { get; set; } = string.Empty;

    public void Dispose()
    {
        autosaveCancellationTokenSource?.Cancel();
        autosaveCancellationTokenSource?.Dispose();
        saveSemaphore.Dispose();
    }
}
