@page "/news"
@page "/news-articles"
@rendermode InteractiveServer
@using System.Text.RegularExpressions
@inject IJSRuntime JSRuntime
@inject IImageStorageService ImageStorageService
@inject INewsArticleService NewsArticleService
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<script>
    window.axlCarousel = window.axlCarousel || {
        isMobileDevice: function () {
            return window.matchMedia("(hover: none) and (pointer: coarse), (any-hover: none) and (any-pointer: coarse)").matches;
        }
    };

    window.axlNewsPage = window.axlNewsPage || (() => {
        let observer;

        function initializeInfiniteScroll(sentinel, dotNetReference) {
            if (!sentinel || !dotNetReference) {
                return;
            }

            disposeInfiniteScroll();

            observer = new IntersectionObserver(entries => {
                const visibleEntry = entries.find(entry => entry.isIntersecting);
                if (!visibleEntry) {
                    return;
                }

                dotNetReference.invokeMethodAsync("LoadMoreFromScroll");
            }, {
                root: null,
                rootMargin: "0px 0px 320px 0px",
                threshold: 0.1
            });

            observer.observe(sentinel);
        }

        function disposeInfiniteScroll() {
            if (observer) {
                observer.disconnect();
                observer = null;
            }
        }

        return {
            initializeInfiniteScroll,
            disposeInfiniteScroll
        };
    })();
</script>

<PageTitle>News Articles</PageTitle>

<div class="news-page">
    <section class="news-page-header">
        <div>
            <p class="eyebrow">Editorial</p>
            <h1>News Articles</h1>
            <p class="news-lead">
                Featured stories lead the page, published articles flow underneath by recency, and admin users can create, edit, schedule, publish, and delete seeded news content directly from this view.
            </p>
        </div>

        <div class="news-summary-card">
            <p class="summary-label">Dataset</p>
            <p class="summary-value">@allArticles.Count stored articles</p>
            <p class="summary-copy">
                Showing @visibleArticles.Count visible articles
                @if (isAdmin)
                {
                    <span> including admin-only scheduled or unpublished entries.</span>
                }
                else
                {
                    <span> that are published and live.</span>
                }
            </p>
        </div>
    </section>

    @if (featuredArticles.Count > 0)
    {
        var activeFeaturedArticle = featuredArticles[activeFeaturedArticleIndex];

        <section
            class="news-carousel"
            aria-label="Featured news articles"
            tabindex="0"
            @onmouseenter="PauseFeaturedCarouselRotation"
            @onmouseleave="ResumeFeaturedCarouselRotation"
            @onkeydown="HandleFeaturedCarouselKeyDown"
            @ontouchstart="HandleFeaturedCarouselTouchStart"
            @ontouchend="HandleFeaturedCarouselTouchEnd">
            <div class="carousel-stage">
                <article class="featured-story" style="@GetFeaturedStyle(activeFeaturedArticle)">
                    <div class="featured-story-overlay">
                        <p class="eyebrow">Featured Article</p>
                        <p class="featured-date">@FormatPublicationLabel(activeFeaturedArticle)</p>
                        <h2>@activeFeaturedArticle.Title</h2>
                        <p class="featured-preview">@GetPreviewText(activeFeaturedArticle.Content, 36)</p>
                        <div class="featured-actions">
                            <button class="btn btn-light" type="button" @onclick="() => OpenArticle(activeFeaturedArticle)">
                                Read More
                            </button>
                            <a class="btn btn-outline-light" href="#news-feed">Jump To Feed</a>
                            @if (isAdmin)
                            {
                                <button class="btn btn-outline-light" type="button" @onclick="() => OpenEditArticle(activeFeaturedArticle)">
                                    Edit Article
                                </button>
                                <button class="btn btn-outline-light" type="button" @onclick="() => OpenDeleteArticle(activeFeaturedArticle)">
                                    Delete Article
                                </button>
                            }
                        </div>
                    </div>
                </article>

                @if (featuredArticles.Count > 1)
                {
                    <button class="carousel-arrow carousel-arrow-overlay carousel-arrow-left" type="button" @onclick="ShowPreviousFeaturedArticle" aria-label="Previous featured article">
                        <span aria-hidden="true">&#x2039;</span>
                    </button>

                    <button class="carousel-arrow carousel-arrow-overlay carousel-arrow-right" type="button" @onclick="ShowNextFeaturedArticle" aria-label="Next featured article">
                        <span aria-hidden="true">&#x203A;</span>
                    </button>
                }
            </div>

            @if (featuredArticles.Count > 1)
            {
                <div class="carousel-controls">
                    <div class="hero-carousel-indicators">
                        @for (var index = 0; index < featuredArticles.Count; index++)
                        {
                            var slideIndex = index;
                            <button
                                type="button"
                                class="indicator @(slideIndex == activeFeaturedArticleIndex ? "active" : string.Empty)"
                                @onclick="@(() => ShowFeaturedArticle(slideIndex))"
                                aria-label="Show featured article @(slideIndex + 1)">
                            </button>
                        }
                    </div>
                </div>
            }
        </section>
    }

    <section class="news-feed-header" id="news-feed">
        <div>
            <p class="eyebrow">Latest Articles</p>
            <h2>Most Recent Stories</h2>
        </div>

        <p class="feed-meta">
            @loadedArticles.Count of @feedArticles.Count articles loaded
        </p>
    </section>

    <section class="news-workspace">
        <div class="news-feed-column">
            <section class="article-grid" aria-label="News article feed">
                @foreach (var article in loadedArticles)
                {
                    <article class="article-card @(IsSelectedArticle(article) ? "is-selected" : string.Empty)" style="@GetCardStyle(article)">
                        <div class="article-card-overlay">
                            <div class="article-card-meta">
                                <p class="article-card-date">@FormatPublicationLabel(article)</p>
                                @if (isAdmin && !IsLiveForPublic(article))
                                {
                                    <span class="article-visibility-badge">Admin Preview</span>
                                }
                            </div>

                            <h3>@article.Title</h3>
                            <p class="article-preview">@GetPreviewText(article.Content, 50)</p>
                            <div class="article-card-actions">
                                <button class="btn btn-primary" type="button" @onclick="() => OpenArticle(article)">
                                    Read More
                                </button>
                                @if (isAdmin)
                                {
                                    <button class="btn btn-outline-light article-edit-button" type="button" @onclick="() => OpenEditArticle(article)">
                                        Edit
                                    </button>
                                    <button class="btn btn-outline-danger article-delete-button" type="button" @onclick="() => OpenDeleteArticle(article)">
                                        Delete
                                    </button>
                                }
                            </div>
                        </div>
                    </article>
                }
            </section>

            @if (hasMoreArticles)
            {
                <div class="scroll-loader">
                    <div @ref="loadMoreSentinel" class="news-scroll-sentinel" aria-hidden="true"></div>
                    <p>@(isLoadingMore ? "Loading more articles..." : "Continue scrolling to load more articles.")</p>
                </div>
            }
            else
            {
                <div class="scroll-loader is-complete">
                    <p>All visible articles are loaded.</p>
                </div>
            }
        </div>

        <aside class="news-detail-pane" aria-label="Selected article details">
            @if (selectedArticle is not null)
            {
                <div class="news-detail-surface">
                    <div class="news-detail-header">
                        <div>
                            <p class="eyebrow">News Article</p>
                            <h3 class="news-detail-title">@selectedArticle.Title</h3>
                            <p class="news-detail-date">@FormatPublicationLabel(selectedArticle)</p>
                        </div>
                        @if (isAdmin)
                        {
                            <div class="news-detail-header-actions">
                                <button class="btn btn-outline-primary btn-sm" type="button" @onclick="() => OpenEditArticle(selectedArticle)">
                                    Edit Article
                                </button>
                                <button class="btn btn-outline-danger btn-sm" type="button" @onclick="() => OpenDeleteArticle(selectedArticle)">
                                    Delete Article
                                </button>
                            </div>
                        }
                    </div>

                    <div class="news-detail-body">
                        @if (!string.IsNullOrWhiteSpace(selectedArticle.ImageUrl))
                        {
                            <div class="news-detail-image">
                                <img src="@selectedArticle.ImageUrl" alt="@selectedArticle.Title hero image" />
                            </div>
                        }

                        <MarkdownRenderer Content="@selectedArticle.Content" CssClass="news-detail-markdown" />
                    </div>
                </div>
            }
            else
            {
                <div class="news-detail-surface news-detail-empty">
                    <p class="eyebrow">Article Pane</p>
                    <h3 class="news-detail-title">Choose A Story</h3>
                    <p>Select a featured story or feed card to open the full article here without leaving the page.</p>
                </div>
            }
        </aside>
    </section>
</div>

@if (isEditModalOpen && editableArticle is not null)
{
    <div class="news-modal-overlay" tabindex="-1" role="dialog" aria-modal="true">
        <div class="news-modal-dialog" role="document" @onclick:stopPropagation="true">
            <div class="news-modal-surface admin-edit-surface">
                <div class="news-modal-header">
                    <div>
                        <p class="eyebrow">Admin</p>
                        <h3 class="news-modal-title">@(isCreatingArticle ? "Create Article" : "Edit Article")</h3>
                        <p class="news-modal-date">Database-backed news editor</p>
                    </div>

                    <button type="button" class="btn-close" aria-label="Close" @onclick="CloseEditArticle"></button>
                </div>

                @if (!string.IsNullOrWhiteSpace(editErrorMessage))
                {
                    <div class="alert alert-danger admin-edit-alert" role="alert">@editErrorMessage</div>
                }

                @if (!string.IsNullOrWhiteSpace(editStatusMessage))
                {
                    <div class="alert alert-success admin-edit-alert" role="alert">@editStatusMessage</div>
                }

                <div class="admin-edit-form">
                    <div class="mb-3">
                        <label class="form-label" for="news-title">Title</label>
                        <input class="form-control" id="news-title" @bind="editableArticle.Title" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="news-image-url">Image Url</label>
                        <input class="form-control" id="news-image-url" @bind="editableArticle.ImageUrl" />
                        <div class="form-text">Paste an existing image URL or upload a new image below.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="news-image-upload">Upload Image</label>
                        <InputFile id="news-image-upload" OnChange="HandleArticleImageSelectedAsync" accept=".jpg,.jpeg,.png,.webp,.gif" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="news-publication-date">Publication Date</label>
                        <InputDate class="form-control" id="news-publication-date" @bind-Value="editablePublicationDate" />
                    </div>

                    <div class="admin-checkbox-row mb-3">
                        <label class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="editableArticle.IsPublished" />
                            <span class="form-check-label">Published</span>
                        </label>

                        <label class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="editableArticle.IsFeatured" />
                            <span class="form-check-label">Featured</span>
                        </label>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="news-content">Content</label>
                        <MarkdownEditor Id="news-content" InputName="" Rows="14" EditorClass="form-control admin-content-editor" @bind-Value="editableArticle.Content" />
                    </div>

                    <div class="admin-edit-actions">
                        <button class="btn btn-outline-secondary" type="button" @onclick="CloseEditArticle">Cancel</button>
                        <button class="btn btn-primary" type="button" @onclick="SaveEditedArticle">
                            @(isCreatingArticle ? "Create Article" : "Save Changes")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (isDeleteModalOpen && articlePendingDelete is not null)
{
    <div class="news-modal-overlay" tabindex="-1" role="dialog" aria-modal="true" @onclick="CloseDeleteArticle">
        <div class="news-modal-dialog" role="document" @onclick:stopPropagation="true">
            <div class="news-modal-surface delete-confirm-surface">
                <div class="news-modal-header">
                    <div>
                        <p class="eyebrow">Admin</p>
                        <h3 class="news-modal-title">Delete Article</h3>
                        <p class="news-modal-date">This action removes the article from the database.</p>
                    </div>

                    <button type="button" class="btn-close" aria-label="Close" @onclick="CloseDeleteArticle"></button>
                </div>

                <div class="delete-confirm-body">
                    <p>Are you sure you want to delete <strong>@articlePendingDelete.Title</strong>?</p>
                    <p>This updates the featured carousel, feed, and article modal immediately.</p>
                </div>

                <div class="admin-edit-actions delete-confirm-actions">
                    <button class="btn btn-outline-secondary" type="button" @onclick="CloseDeleteArticle">Cancel</button>
                    <button class="btn btn-danger" type="button" @onclick="ConfirmDeleteArticle">Delete Article</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    [SupplyParameterFromQuery(Name = "editor")]
    public string? EditorMode { get; set; }

    [SupplyParameterFromQuery(Name = "article")]
    public string? ArticleSlug { get; set; }

    private const int FeedBatchSize = 9;
    private const double SwipeThreshold = 48;
    private static readonly TimeSpan CarouselRotationInterval = TimeSpan.FromSeconds(5);

    private List<NewsArticle> allArticles = [];
    private List<NewsArticle> visibleArticles = [];
    private List<NewsArticle> featuredArticles = [];
    private List<NewsArticle> feedArticles = [];
    private List<NewsArticle> loadedArticles = [];
    private CancellationTokenSource? featuredCarouselRotationCancellationTokenSource;
    private NewsArticle? selectedArticle;
    private NewsArticle? editableArticle;
    private NewsArticle? articlePendingDelete;
    private DotNetObjectReference<News>? dotNetReference;
    private ElementReference loadMoreSentinel;
    private int activeFeaturedArticleIndex;
    private double? featuredCarouselTouchStartX;
    private bool isAdmin;
    private bool hasMoreArticles;
    private bool isLoadingMore;
    private bool isMobileDevice;
    private bool observerInitialized;
    private bool isEditModalOpen;
    private bool isCreatingArticle;
    private bool isDeleteModalOpen;
    private bool isFeaturedCarouselHovered;
    private DateTime editablePublicationDate;
    private string? editErrorMessage;
    private string? editStatusMessage;

    protected override async Task OnInitializedAsync()
    {
        var authenticationState = AuthenticationStateTask is null
            ? null
            : await AuthenticationStateTask;

        isAdmin = authenticationState?.User.IsInRole("Admin") == true;
        await RefreshVisibleArticlesAsync();

        if (isAdmin && string.Equals(EditorMode, "new", StringComparison.OrdinalIgnoreCase))
        {
            OpenCreateArticle();
        }
    }

    protected override void OnParametersSet()
    {
        SyncSelectedArticleFromQuery();

        if (isAdmin
            && !isEditModalOpen
            && string.Equals(EditorMode, "new", StringComparison.OrdinalIgnoreCase))
        {
            OpenCreateArticle();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            isMobileDevice = await DetectMobileDeviceAsync();

            if (!isMobileDevice)
            {
                StartFeaturedCarouselRotation();
            }
        }

        if ((!firstRender && observerInitialized) || !hasMoreArticles)
        {
            return;
        }

        dotNetReference ??= DotNetObjectReference.Create(this);
        await JSRuntime.InvokeVoidAsync("axlNewsPage.initializeInfiniteScroll", loadMoreSentinel, dotNetReference);
        observerInitialized = true;
    }

    [JSInvokable]
    public async Task LoadMoreFromScroll()
    {
        if (!hasMoreArticles || isLoadingMore)
        {
            return;
        }

        isLoadingMore = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(180);
        LoadNextBatch();
        isLoadingMore = false;
        await InvokeAsync(StateHasChanged);
    }

    private void LoadNextBatch()
    {
        if (!hasMoreArticles && loadedArticles.Count > 0)
        {
            return;
        }

        var nextItems = feedArticles
            .Skip(loadedArticles.Count)
            .Take(FeedBatchSize)
            .ToList();

        if (nextItems.Count > 0)
        {
            loadedArticles.AddRange(nextItems);
        }

        hasMoreArticles = loadedArticles.Count < feedArticles.Count;
    }

    private static bool IsLiveForPublic(NewsArticle article)
    {
        var publicCutoff = DateTimeOffset.UtcNow.AddMonths(-3);

        return article.IsPublished
            && article.PublicationDateUtc <= DateTimeOffset.UtcNow
            && article.PublicationDateUtc >= publicCutoff;
    }

    private void OpenArticle(NewsArticle article)
    {
        selectedArticle = article;
        SetArticleQueryParameter(article.Slug);
    }

    private void CloseArticle()
    {
        selectedArticle = null;
        RemoveArticleQueryParameter();
    }

    private void OpenEditArticle(NewsArticle article)
    {
        editableArticle = CloneArticle(article);
        editablePublicationDate = article.PublicationDateUtc.UtcDateTime.Date;
        editErrorMessage = null;
        editStatusMessage = null;
        isCreatingArticle = false;
        isEditModalOpen = true;
    }

    private void OpenCreateArticle()
    {
        editableArticle = new NewsArticle
        {
            Id = Guid.NewGuid().ToString("N"),
            Slug = string.Empty,
            Title = string.Empty,
            Content = string.Empty,
            ImageUrl = string.Empty,
            PublicationDateUtc = DateTimeOffset.UtcNow,
            IsPublished = false,
            IsFeatured = false
        };
        editablePublicationDate = DateTime.UtcNow.Date;
        editErrorMessage = null;
        editStatusMessage = null;
        isCreatingArticle = true;
        isEditModalOpen = true;
    }

    private void OpenDeleteArticle(NewsArticle article)
    {
        articlePendingDelete = article;
        isDeleteModalOpen = true;
    }

    private void CloseEditArticle()
    {
        isEditModalOpen = false;
        editableArticle = null;
        editErrorMessage = null;
        editStatusMessage = null;
        isCreatingArticle = false;
        RemoveEditorQueryParameter();
    }

    private void CloseDeleteArticle()
    {
        isDeleteModalOpen = false;
        articlePendingDelete = null;
    }

    private void ShowPreviousFeaturedArticle()
    {
        if (featuredArticles.Count == 0)
        {
            return;
        }

        activeFeaturedArticleIndex = (activeFeaturedArticleIndex - 1 + featuredArticles.Count) % featuredArticles.Count;
    }

    private void ShowNextFeaturedArticle()
    {
        if (featuredArticles.Count == 0)
        {
            return;
        }

        activeFeaturedArticleIndex = (activeFeaturedArticleIndex + 1) % featuredArticles.Count;
    }

    private void ShowFeaturedArticle(int index)
    {
        activeFeaturedArticleIndex = index;
    }

    private void PauseFeaturedCarouselRotation()
    {
        isFeaturedCarouselHovered = true;
    }

    private void ResumeFeaturedCarouselRotation()
    {
        isFeaturedCarouselHovered = false;
    }

    private void HandleFeaturedCarouselKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "ArrowLeft")
        {
            ShowPreviousFeaturedArticle();
        }
        else if (args.Key == "ArrowRight")
        {
            ShowNextFeaturedArticle();
        }
    }

    private void HandleFeaturedCarouselTouchStart(TouchEventArgs args)
    {
        featuredCarouselTouchStartX = args.Touches.FirstOrDefault()?.ClientX ?? args.ChangedTouches.FirstOrDefault()?.ClientX;
    }

    private void HandleFeaturedCarouselTouchEnd(TouchEventArgs args)
    {
        if (featuredCarouselTouchStartX is null)
        {
            return;
        }

        var touchEndX = args.ChangedTouches.FirstOrDefault()?.ClientX;
        if (touchEndX is null)
        {
            featuredCarouselTouchStartX = null;
            return;
        }

        var deltaX = touchEndX.Value - featuredCarouselTouchStartX.Value;
        featuredCarouselTouchStartX = null;

        if (Math.Abs(deltaX) < SwipeThreshold)
        {
            return;
        }

        if (deltaX < 0)
        {
            ShowNextFeaturedArticle();
        }
        else
        {
            ShowPreviousFeaturedArticle();
        }
    }

    private void StartFeaturedCarouselRotation()
    {
        featuredCarouselRotationCancellationTokenSource?.Cancel();
        featuredCarouselRotationCancellationTokenSource?.Dispose();
        featuredCarouselRotationCancellationTokenSource = new CancellationTokenSource();
        _ = RotateFeaturedCarouselAsync(featuredCarouselRotationCancellationTokenSource.Token);
    }

    private async Task RotateFeaturedCarouselAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(CarouselRotationInterval);

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (isFeaturedCarouselHovered || featuredArticles.Count <= 1)
                {
                    continue;
                }

                await InvokeAsync(() =>
                {
                    ShowNextFeaturedArticle();
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task<bool> DetectMobileDeviceAsync()
    {
        try
        {
            return await JSRuntime.InvokeAsync<bool>("axlCarousel.isMobileDevice");
        }
        catch
        {
            return false;
        }
    }

    private async Task SaveEditedArticle()
    {
        if (editableArticle is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(editableArticle.Title))
        {
            editErrorMessage = "Title is required.";
            editStatusMessage = null;
            return;
        }

        if (string.IsNullOrWhiteSpace(editableArticle.Content))
        {
            editErrorMessage = "Content is required.";
            editStatusMessage = null;
            return;
        }

        try
        {
            if (isCreatingArticle)
            {
                await NewsArticleService.CreateAsync(BuildUpdateRequest());
                await RefreshVisibleArticlesAsync();
                CloseEditArticle();
                return;
            }

            var previousImageUrl = allArticles
                .FirstOrDefault(article => article.Id == editableArticle.Id)?
                .ImageUrl;

            var updatedArticle = await NewsArticleService.UpdateAsync(BuildUpdateRequest());

            if (!string.IsNullOrWhiteSpace(previousImageUrl)
                && NewsArticleService.IsManagedImageUrl(previousImageUrl)
                && !string.Equals(previousImageUrl, updatedArticle.ImageUrl, StringComparison.OrdinalIgnoreCase))
            {
                await ImageStorageService.DeleteAsync(previousImageUrl);
            }

            await RefreshVisibleArticlesAsync(updatedArticle.Id);
            CloseEditArticle();
        }
        catch (Exception exception)
        {
            editErrorMessage = exception.Message;
            editStatusMessage = null;
        }
    }

    private async Task HandleArticleImageSelectedAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null || editableArticle is null)
        {
            return;
        }

        editErrorMessage = null;
        editStatusMessage = "Uploading article image...";
        await InvokeAsync(StateHasChanged);

        try
        {
            await using var readStream = file.OpenReadStream(5 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await readStream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            var formFile = new Microsoft.AspNetCore.Http.FormFile(memoryStream, 0, memoryStream.Length, file.Name, file.Name)
            {
                Headers = new Microsoft.AspNetCore.Http.HeaderDictionary(),
                ContentType = file.ContentType
            };

            var imageSaveResult = await ImageStorageService.SaveReleaseImageAsync(formFile);

            if (!string.IsNullOrWhiteSpace(editableArticle.ImageUrl)
                && NewsArticleService.IsManagedImageUrl(editableArticle.ImageUrl)
                && !string.Equals(editableArticle.ImageUrl, imageSaveResult.Url, StringComparison.OrdinalIgnoreCase))
            {
                await ImageStorageService.DeleteAsync(editableArticle.ImageUrl);
            }

            editableArticle.ImageUrl = imageSaveResult.Url;
            editStatusMessage = "Article image uploaded.";
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception exception)
        {
            editErrorMessage = exception.Message;
            editStatusMessage = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ConfirmDeleteArticle()
    {
        if (articlePendingDelete is null)
        {
            return;
        }

        if (!string.IsNullOrWhiteSpace(articlePendingDelete.ImageUrl)
            && NewsArticleService.IsManagedImageUrl(articlePendingDelete.ImageUrl))
        {
            await ImageStorageService.DeleteAsync(articlePendingDelete.ImageUrl);
        }

        await NewsArticleService.DeleteAsync(articlePendingDelete.Id);

        if (selectedArticle?.Id == articlePendingDelete.Id)
        {
            selectedArticle = null;
        }

        if (editableArticle?.Id == articlePendingDelete.Id)
        {
            CloseEditArticle();
        }

        await RefreshVisibleArticlesAsync();
        CloseDeleteArticle();
    }

    private static string GetPreviewText(string content, int wordCount)
    {
        var previewSource = Regex.Replace(content ?? string.Empty, @"[#>*_`~\[\]\(\)!-]+", " ");
        var words = Regex.Split(previewSource.Trim(), @"\s+")
            .Where(word => !string.IsNullOrWhiteSpace(word))
            .ToList();

        if (words.Count <= wordCount)
        {
            return string.Join(' ', words);
        }

        return $"{string.Join(' ', words.Take(wordCount))}...";
    }

    private static string FormatPublicationLabel(NewsArticle article)
    {
        var label = article.PublicationDateUtc.ToLocalTime().ToString("MMMM d, yyyy");
        if (!article.IsPublished)
        {
            return $"Unpublished - {label}";
        }

        if (article.PublicationDateUtc > DateTimeOffset.UtcNow)
        {
            return $"Scheduled - {label}";
        }

        return label;
    }

    private static string GetCardStyle(NewsArticle article)
    {
        if (string.IsNullOrWhiteSpace(article.ImageUrl))
        {
            return string.Empty;
        }

        return $"background-image: linear-gradient(180deg, rgba(8, 14, 28, 0.16), rgba(8, 14, 28, 0.88)), url('{article.ImageUrl}');";
    }

    private static string GetFeaturedStyle(NewsArticle article)
    {
        if (string.IsNullOrWhiteSpace(article.ImageUrl))
        {
            return string.Empty;
        }

        return $"background-image: linear-gradient(180deg, rgba(8, 14, 28, 0.24), rgba(8, 14, 28, 0.88)), url('{article.ImageUrl}');";
    }

    private async Task RefreshVisibleArticlesAsync(string? focusArticleId = null)
    {
        var loadedCount = loadedArticles.Count;

        allArticles = (await NewsArticleService.GetArticlesAsync(includeUnpublished: true)).ToList();
        visibleArticles = isAdmin
            ? allArticles.ToList()
            : allArticles.Where(IsLiveForPublic).ToList();

        featuredArticles = visibleArticles
            .Where(article => article.IsFeatured)
            .OrderByDescending(article => article.PublicationDateUtc)
            .ToList();

        feedArticles = visibleArticles
            .Where(article => !article.IsFeatured)
            .OrderByDescending(article => article.PublicationDateUtc)
            .ToList();

        loadedArticles = feedArticles
            .Take(Math.Min(Math.Max(loadedCount, FeedBatchSize), feedArticles.Count))
            .ToList();

        hasMoreArticles = loadedArticles.Count < feedArticles.Count;

        if (featuredArticles.Count == 0)
        {
            activeFeaturedArticleIndex = 0;
        }
        else if (focusArticleId is not null)
        {
            var focusedIndex = featuredArticles.FindIndex(article => article.Id == focusArticleId);
            activeFeaturedArticleIndex = focusedIndex >= 0
                ? focusedIndex
                : Math.Min(activeFeaturedArticleIndex, featuredArticles.Count - 1);
        }
        else
        {
            activeFeaturedArticleIndex = Math.Min(activeFeaturedArticleIndex, featuredArticles.Count - 1);
        }

        if (selectedArticle is not null)
        {
            selectedArticle = visibleArticles.FirstOrDefault(article => article.Id == selectedArticle.Id);
        }
        
        SyncSelectedArticleFromQuery();
    }

    private void SyncSelectedArticleFromQuery()
    {
        if (string.IsNullOrWhiteSpace(ArticleSlug))
        {
            return;
        }

        selectedArticle = visibleArticles.FirstOrDefault(article =>
            string.Equals(article.Slug, ArticleSlug, StringComparison.OrdinalIgnoreCase));
    }

    private bool IsSelectedArticle(NewsArticle article)
        => selectedArticle is not null
            && string.Equals(selectedArticle.Id, article.Id, StringComparison.Ordinal);

    private NewsArticleUpdateRequest BuildUpdateRequest()
    {
        return new NewsArticleUpdateRequest
        {
            OriginalSlug = isCreatingArticle ? null : editableArticle?.Slug,
            Title = editableArticle?.Title ?? string.Empty,
            Content = editableArticle?.Content ?? string.Empty,
            ImageUrl = editableArticle?.ImageUrl ?? string.Empty,
            PublicationDate = editablePublicationDate,
            IsPublished = editableArticle?.IsPublished == true,
            IsFeatured = editableArticle?.IsFeatured == true
        };
    }

    private void RemoveEditorQueryParameter()
    {
        var targetUri = BuildUriWithoutQueryKeys("editor");
        NavigationManager.NavigateTo(targetUri, replace: true);
    }

    private void RemoveArticleQueryParameter()
    {
        var targetUri = BuildUriWithoutQueryKeys("article");
        NavigationManager.NavigateTo(targetUri, replace: true);
    }

    private void SetArticleQueryParameter(string slug)
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query)
            .Where(entry => !string.Equals(entry.Key, "article", StringComparison.OrdinalIgnoreCase))
            .ToDictionary(entry => entry.Key, entry => (string?)entry.Value.ToString(), StringComparer.OrdinalIgnoreCase);

        query["article"] = slug;

        var targetUri = Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
            uri.GetLeftPart(UriPartial.Path),
            query);

        NavigationManager.NavigateTo(targetUri, replace: true);
    }

    private string BuildUriWithoutQueryKeys(params string[] keysToRemove)
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        var filteredEntries = query
            .Where(entry => !keysToRemove.Any(key => string.Equals(entry.Key, key, StringComparison.OrdinalIgnoreCase)))
            .SelectMany(entry => entry.Value, (entry, value) => new KeyValuePair<string, string?>(entry.Key, value));

        return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
            uri.GetLeftPart(UriPartial.Path),
            filteredEntries);
    }

    private static NewsArticle CloneArticle(NewsArticle article)
    {
        return new NewsArticle
        {
            Id = article.Id,
            Title = article.Title,
            Slug = article.Slug,
            Content = article.Content,
            ImageUrl = article.ImageUrl,
            PublicationDateUtc = article.PublicationDateUtc,
            IsPublished = article.IsPublished,
            IsFeatured = article.IsFeatured
        };
    }

    public async ValueTask DisposeAsync()
    {
        featuredCarouselRotationCancellationTokenSource?.Cancel();
        featuredCarouselRotationCancellationTokenSource?.Dispose();

        try
        {
            await JSRuntime.InvokeVoidAsync("axlNewsPage.disposeInfiniteScroll");
        }
        catch
        {
        }

        dotNetReference?.Dispose();
    }
}
