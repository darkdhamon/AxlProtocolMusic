@page "/"
@rendermode InteractiveServer
@using AxlProtocolMusic.WebApp.Services.ServiceModels
@inject IJSRuntime JSRuntime
@inject IReleaseService ReleaseService
@implements IAsyncDisposable

<script>
    window.axlCarousel = window.axlCarousel || {
        isMobileDevice: function () {
            return window.matchMedia("(hover: none) and (pointer: coarse), (any-hover: none) and (any-pointer: coarse)").matches;
        }
    };
</script>

<PageTitle>Home</PageTitle>

<div class="home-page">
    <section
        class="hero-carousel"
        tabindex="0"
        @onmouseenter="PauseCarouselRotation"
        @onmouseleave="ResumeCarouselRotation"
        @onkeydown="HandleCarouselKeyDown"
        @ontouchstart="HandleCarouselTouchStart"
        @ontouchend="HandleCarouselTouchEnd">
        @if (isLoading)
        {
            <div class="hero-shell">
                <p><em>Loading featured releases...</em></p>
            </div>
        }
        else if (featuredReleases.Count == 0)
        {
            <div class="hero-shell empty-state">
                <div>
                    <p class="eyebrow">Latest Releases</p>
                    <h1>Axl Protocol Music</h1>
                    <p>
                        Featured releases will appear here as soon as published music is added to the catalog.
                    </p>
                    <a class="btn btn-light" href="/releases">Browse Releases</a>
                </div>
            </div>
        }
        else
        {
            var activeRelease = featuredReleases[activeSlideIndex];
            var isUpcomingRelease = IsUpcomingRelease(activeRelease.ReleaseDateUtc);

            <div class="carousel-stage">
                <div class="hero-shell hero-shell-image-left">
                    <div class="hero-artwork">
                        <div class="hero-artwork-frame">
                            <img
                                class="@(isUpcomingRelease ? "is-upcoming" : null)"
                                src="@GetReleaseArtworkUrl(activeRelease.CoverImageUrl)"
                                alt="@activeRelease.Title cover art"
                                onerror="this.onerror=null;this.src='/Assets/Misc/Placeholder-AlbumArt.png';" />

                            @if (isUpcomingRelease)
                            {
                                <div class="hero-artwork-overlay" aria-hidden="true">
                                    <div class="release-coming-soon-group">
                                        <span class="release-coming-soon-label">Coming Soon</span>
                                        <span class="release-coming-soon-date">@activeRelease.ReleaseDateUtc.ToLocalTime().ToString("MMMM dd, yyyy")</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="hero-copy">
                        <p class="eyebrow">Latest Releases</p>
                        <h1>@activeRelease.Title</h1>
                        <p class="hero-date">@activeRelease.ReleaseDateUtc.ToLocalTime().ToString("MMMM d, yyyy")</p>
                        <p class="hero-description">@activeRelease.ShortDescription</p>
                        <div class="hero-actions">
                            <a class="btn btn-light" href="@($"/releases/{activeRelease.Slug}")">View Release</a>
                            <button class="btn btn-outline-light" type="button" @onclick="ShowNextSlide">
                                Next Release
                            </button>
                        </div>
                    </div>
                </div>

                @if (featuredReleases.Count > 1)
                {
                    <button class="carousel-arrow carousel-arrow-overlay carousel-arrow-left" type="button" @onclick="ShowPreviousSlide" aria-label="Previous release">
                        <span aria-hidden="true">&#x2039;</span>
                    </button>

                    <button class="carousel-arrow carousel-arrow-overlay carousel-arrow-right" type="button" @onclick="ShowNextSlide" aria-label="Next release">
                        <span aria-hidden="true">&#x203A;</span>
                    </button>
                }
            </div>

            @if (featuredReleases.Count > 1)
            {
                <div class="carousel-controls">
                    <div class="hero-carousel-indicators">
                        @for (var index = 0; index < featuredReleases.Count; index++)
                        {
                            var slideIndex = index;
                            <button
                                type="button"
                                class="indicator @(slideIndex == activeSlideIndex ? "active" : string.Empty)"
                                @onclick="@(() => ShowSlide(slideIndex))"
                                aria-label="Show release @(slideIndex + 1)">
                            </button>
                        }
                    </div>
                </div>
            }
        }
    </section>

    <section class="home-intro">
        <div class="intro-card">
            <p class="eyebrow">Artist and Label</p>
            <h2>Axl Protocol and Axl Protocol Music</h2>
            <p>
                This site will be the official home for releases, artist context, and the stories behind the music.
            </p>
        </div>

        <div class="intro-grid">
            <a class="feature-card" href="/about-axl-protocol">
                <p class="eyebrow">Story</p>
                <h3>About Axl Protocol</h3>
                <p>Learn about the artist, collaborators, and the life behind the project.</p>
            </a>

            <a class="feature-card" href="/news">
                <p class="eyebrow">Updates</p>
                <h3>News Articles</h3>
                <p>Follow announcements, release updates, and major milestones.</p>
            </a>

            <a class="feature-card" href="/timeline">
                <p class="eyebrow">History</p>
                <h3>Timeline</h3>
                <p>Trace the defining moments, releases, and eras that shape the catalog.</p>
            </a>
        </div>
    </section>
</div>

@code {
    private const string PlaceholderAlbumArtPath = "/Assets/Misc/Placeholder-AlbumArt.png";
    private const double SwipeThreshold = 48;
    private static readonly TimeSpan CarouselRotationInterval = TimeSpan.FromSeconds(5);
    private IReadOnlyList<FeaturedReleaseViewModel> featuredReleases = [];
    private CancellationTokenSource? carouselRotationCancellationTokenSource;
    private int activeSlideIndex;
    private double? touchStartX;
    private bool isLoading = true;
    private bool isCarouselHovered;
    private bool isMobileDevice;

    protected override async Task OnInitializedAsync()
    {
        featuredReleases = await ReleaseService.GetFeaturedReleasesAsync();
        activeSlideIndex = 0;
        isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        isMobileDevice = await DetectMobileDeviceAsync();

        if (!isMobileDevice)
        {
            StartCarouselRotation();
        }
    }

    private void ShowPreviousSlide()
    {
        if (featuredReleases.Count == 0)
        {
            return;
        }

        activeSlideIndex = (activeSlideIndex - 1 + featuredReleases.Count) % featuredReleases.Count;
    }

    private void ShowNextSlide()
    {
        if (featuredReleases.Count == 0)
        {
            return;
        }

        activeSlideIndex = (activeSlideIndex + 1) % featuredReleases.Count;
    }

    private void ShowSlide(int slideIndex)
    {
        activeSlideIndex = slideIndex;
    }

    private void PauseCarouselRotation()
    {
        isCarouselHovered = true;
    }

    private void ResumeCarouselRotation()
    {
        isCarouselHovered = false;
    }

    private void HandleCarouselKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "ArrowLeft")
        {
            ShowPreviousSlide();
        }
        else if (args.Key == "ArrowRight")
        {
            ShowNextSlide();
        }
    }

    private void HandleCarouselTouchStart(TouchEventArgs args)
    {
        touchStartX = args.Touches.FirstOrDefault()?.ClientX ?? args.ChangedTouches.FirstOrDefault()?.ClientX;
    }

    private void HandleCarouselTouchEnd(TouchEventArgs args)
    {
        if (touchStartX is null)
        {
            return;
        }

        var touchEndX = args.ChangedTouches.FirstOrDefault()?.ClientX;
        if (touchEndX is null)
        {
            touchStartX = null;
            return;
        }

        var deltaX = touchEndX.Value - touchStartX.Value;
        touchStartX = null;

        if (Math.Abs(deltaX) < SwipeThreshold)
        {
            return;
        }

        if (deltaX < 0)
        {
            ShowNextSlide();
        }
        else
        {
            ShowPreviousSlide();
        }
    }

    private void StartCarouselRotation()
    {
        carouselRotationCancellationTokenSource?.Cancel();
        carouselRotationCancellationTokenSource?.Dispose();
        carouselRotationCancellationTokenSource = new CancellationTokenSource();
        _ = RotateCarouselAsync(carouselRotationCancellationTokenSource.Token);
    }

    private async Task RotateCarouselAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(CarouselRotationInterval);

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (isCarouselHovered || featuredReleases.Count <= 1)
                {
                    continue;
                }

                await InvokeAsync(() =>
                {
                    ShowNextSlide();
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task<bool> DetectMobileDeviceAsync()
    {
        try
        {
            return await JSRuntime.InvokeAsync<bool>("axlCarousel.isMobileDevice");
        }
        catch
        {
            return false;
        }
    }

    private static string GetReleaseArtworkUrl(string? coverImageUrl)
        => string.IsNullOrWhiteSpace(coverImageUrl)
            ? PlaceholderAlbumArtPath
            : coverImageUrl;

    private static bool IsUpcomingRelease(DateTimeOffset releaseDateUtc)
        => releaseDateUtc > DateTimeOffset.UtcNow;

    public ValueTask DisposeAsync()
    {
        carouselRotationCancellationTokenSource?.Cancel();
        carouselRotationCancellationTokenSource?.Dispose();
        return ValueTask.CompletedTask;
    }
}
