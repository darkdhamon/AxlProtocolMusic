@page "/releases"
@rendermode InteractiveServer
@inject IReleaseService ReleaseService

<PageTitle>Releases</PageTitle>

<div class="releases-page">
    <section class="releases-header">
        <div>
            <p class="eyebrow">Catalog</p>
            <h1>Releases</h1>
            <p class="lead">
                Browse published Axl Protocol releases, filter the catalog, and explore the growing discography.
            </p>

            @if (includeUnpublished)
            {
                <div class="mt-3">
                    <a class="btn btn-primary" href="/releases/new">Add Release</a>
                </div>
            }
        </div>

        <form class="search-panel" @onsubmit="HandleSearchAsync">
            <label class="form-label" for="release-search">Search releases</label>
            <div class="search-row">
                <input
                    id="release-search"
                    class="form-control"
                    @bind="searchInput"
                    @bind:event="oninput"
                    placeholder="Search by title or description" />
                <button class="btn btn-primary" type="submit">Search</button>
            </div>
        </form>
    </section>

    @if (isLoading)
    {
        <p><em>Loading releases...</em></p>
    }
    else if (pagedReleases is null || pagedReleases.Items.Count == 0)
    {
        <div class="empty-results">
            <h2>No releases found</h2>
            <p>Try a different search or clear the filter to see the full catalog.</p>
            @if (!string.IsNullOrWhiteSpace(searchInput))
            {
                <button class="btn btn-outline-primary" type="button" @onclick="ClearSearchAsync">Clear Search</button>
            }
        </div>
    }
    else
    {
        <div class="results-meta">
            <p>
                Showing @pagedReleases.Items.Count of @pagedReleases.TotalCount releases
                @if (!string.IsNullOrWhiteSpace(pagedReleases.SearchTerm))
                {
                    <span> for "@pagedReleases.SearchTerm"</span>
                }
            </p>
        </div>

        <section class="release-grid">
            @foreach (var release in pagedReleases.Items)
            {
                <a class="release-card-link" href="@($"/releases/{release.Slug}")">
                    <article class="release-card">
                        @if (!string.IsNullOrWhiteSpace(release.CoverImageUrl))
                        {
                            <img class="release-artwork" src="@release.CoverImageUrl" alt="@release.Title cover art" />
                        }
                        else
                        {
                            <div class="release-artwork placeholder">
                                <span>@release.Title</span>
                            </div>
                        }

                        <div class="release-copy">
                            <div class="release-meta-row">
                                <p class="release-date">@release.ReleaseDateUtc.ToLocalTime().ToString("MMMM d, yyyy")</p>
                                @if (!release.IsPublished)
                                {
                                    <span class="release-status-badge">Unpublished</span>
                                }
                            </div>
                            <h2>@release.Title</h2>
                            <p>@release.ShortDescription</p>
                        </div>
                    </article>
                </a>
            }
        </section>

        <nav class="pagination-row" aria-label="Release pagination">
            <button
                class="btn btn-outline-primary"
                type="button"
                @onclick="ShowPreviousPageAsync"
                disabled="@(pagedReleases.PageNumber <= 1)">
                Previous
            </button>

            <span class="page-status">
                Page @pagedReleases.PageNumber of @pagedReleases.TotalPages
            </span>

            <button
                class="btn btn-outline-primary"
                type="button"
                @onclick="ShowNextPageAsync"
                disabled="@(pagedReleases.PageNumber >= pagedReleases.TotalPages)">
                Next
            </button>
        </nav>
    }
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private const int PageSize = 6;

    private PagedReleaseResult? pagedReleases;
    private string searchInput = string.Empty;
    private bool isLoading = true;
    private bool includeUnpublished;

    protected override async Task OnInitializedAsync()
    {
        var authenticationState = AuthenticationStateTask is null
            ? null
            : await AuthenticationStateTask;

        includeUnpublished = authenticationState?.User.IsInRole("Admin") == true;
        await LoadPageAsync(1);
    }

    private async Task HandleSearchAsync()
    {
        await LoadPageAsync(1);
    }

    private async Task ShowPreviousPageAsync()
    {
        if (pagedReleases is null || pagedReleases.PageNumber <= 1)
        {
            return;
        }

        await LoadPageAsync(pagedReleases.PageNumber - 1);
    }

    private async Task ShowNextPageAsync()
    {
        if (pagedReleases is null || pagedReleases.PageNumber >= pagedReleases.TotalPages)
        {
            return;
        }

        await LoadPageAsync(pagedReleases.PageNumber + 1);
    }

    private async Task ClearSearchAsync()
    {
        searchInput = string.Empty;
        await LoadPageAsync(1);
    }

    private async Task LoadPageAsync(int pageNumber)
    {
        isLoading = true;
        pagedReleases = await ReleaseService.GetPagedReleasesAsync(
            searchInput,
            pageNumber,
            PageSize,
            includeUnpublished);
        isLoading = false;
    }
}
