@page "/releases"
@rendermode InteractiveServer
@inject IJSRuntime JSRuntime
@inject IReleaseService ReleaseService
@implements IAsyncDisposable

<script>
    window.axlReleasesPage = window.axlReleasesPage || (() => {
        let observer;

        function initializeInfiniteScroll(sentinel, dotNetReference) {
            if (!sentinel || !dotNetReference) {
                return;
            }

            disposeInfiniteScroll();

            observer = new IntersectionObserver(entries => {
                const visibleEntry = entries.find(entry => entry.isIntersecting);
                if (!visibleEntry) {
                    return;
                }

                dotNetReference.invokeMethodAsync("LoadMoreFromScroll");
            }, {
                root: null,
                rootMargin: "0px 0px 320px 0px",
                threshold: 0.1
            });

            observer.observe(sentinel);
        }

        function disposeInfiniteScroll() {
            if (observer) {
                observer.disconnect();
                observer = null;
            }
        }

        return {
            initializeInfiniteScroll,
            disposeInfiniteScroll
        };
    })();
</script>

<PageTitle>Releases</PageTitle>

<div class="releases-page">
    <section class="releases-header">
        <div>
            <p class="eyebrow">Catalog</p>
            <h1>Releases</h1>
            <p class="lead">
                Browse published Axl Protocol releases, filter the catalog, and explore the growing discography.
            </p>

            @if (includeUnpublished)
            {
                <div class="mt-3">
                    <a class="btn btn-primary" href="/releases/new">Add Release</a>
                </div>
            }
        </div>

        <form class="search-panel" @onsubmit="HandleSearchAsync">
            <label class="form-label" for="release-search">Search releases</label>
            <div class="search-row">
                <input
                    id="release-search"
                    class="form-control"
                    @bind="searchInput"
                    @bind:event="oninput"
                    placeholder="Search by title or description" />
                <button class="btn btn-primary" type="submit">Search</button>
            </div>
        </form>
    </section>

    @if (isLoading)
    {
        <p><em>Loading releases...</em></p>
    }
    else if (loadedReleases.Count == 0)
    {
        <div class="empty-results">
            <h2>No releases found</h2>
            <p>Try a different search or clear the filter to see the full catalog.</p>
            @if (!string.IsNullOrWhiteSpace(searchInput))
            {
                <button class="btn btn-outline-primary" type="button" @onclick="ClearSearchAsync">Clear Search</button>
            }
        </div>
    }
    else
    {
        <div class="results-meta">
            <p>
                Showing @loadedReleases.Count of @totalCount releases
                @if (!string.IsNullOrWhiteSpace(currentSearchTerm))
                {
                    <span> for "@currentSearchTerm"</span>
                }
            </p>
        </div>

        <section class="release-grid">
            @foreach (var release in loadedReleases)
            {
                <a class="release-card-link" href="@($"/releases/{release.Slug}")">
                    <article class="release-card">
                        <img
                            class="release-artwork"
                            src="@GetReleaseArtworkUrl(release.CoverImageUrl)"
                            alt="@release.Title cover art"
                            onerror="this.onerror=null;this.src='/Assets/Misc/Placeholder-AlbumArt.png';" />

                        <div class="release-copy">
                            <div class="release-meta-row">
                                <p class="release-date">@release.ReleaseDateUtc.ToLocalTime().ToString("MMMM d, yyyy")</p>
                                @if (IsUpcomingRelease(release.ReleaseDateUtc))
                                {
                                    <span class="release-status-badge upcoming-release-badge">Upcoming Release</span>
                                }
                                @if (!release.IsPublished)
                                {
                                    <span class="release-status-badge">Unpublished</span>
                                }
                            </div>
                            <h2>@release.Title</h2>
                            <p>@release.ShortDescription</p>
                        </div>
                    </article>
                </a>
            }
        </section>

        @if (hasMoreReleases)
        {
            <div class="scroll-loader">
                <div @ref="loadMoreSentinel" class="release-scroll-sentinel" aria-hidden="true"></div>
                <p>@(isLoadingMore ? "Loading more releases..." : "Continue scrolling to load more releases.")</p>
            </div>
        }
        else
        {
            <div class="scroll-loader is-complete">
                <p>All visible releases are loaded.</p>
            </div>
        }
    }
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private const int PageSize = 6;
    private const string PlaceholderAlbumArtPath = "/Assets/Misc/Placeholder-AlbumArt.png";

    private readonly List<ReleaseListItemViewModel> loadedReleases = [];
    private DotNetObjectReference<Releases>? dotNetReference;
    private ElementReference loadMoreSentinel;
    private string searchInput = string.Empty;
    private string currentSearchTerm = string.Empty;
    private int currentPageNumber;
    private int totalCount;
    private bool hasMoreReleases;
    private bool isLoading = true;
    private bool isLoadingMore;
    private bool includeUnpublished;
    private bool observerInitialized;

    protected override async Task OnInitializedAsync()
    {
        var authenticationState = AuthenticationStateTask is null
            ? null
            : await AuthenticationStateTask;

        includeUnpublished = authenticationState?.User.IsInRole("Admin") == true;
        await ResetAndLoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!hasMoreReleases || observerInitialized)
        {
            return;
        }

        dotNetReference ??= DotNetObjectReference.Create(this);
        await JSRuntime.InvokeVoidAsync("axlReleasesPage.initializeInfiniteScroll", loadMoreSentinel, dotNetReference);
        observerInitialized = true;
    }

    [JSInvokable]
    public async Task LoadMoreFromScroll()
    {
        if (!hasMoreReleases || isLoading || isLoadingMore)
        {
            return;
        }

        isLoadingMore = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(180);
        await LoadNextPageAsync();
        isLoadingMore = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleSearchAsync()
    {
        await ResetAndLoadAsync();
    }

    private async Task ClearSearchAsync()
    {
        searchInput = string.Empty;
        await ResetAndLoadAsync();
    }

    private async Task ResetAndLoadAsync()
    {
        if (observerInitialized)
        {
            await JSRuntime.InvokeVoidAsync("axlReleasesPage.disposeInfiniteScroll");
        }

        observerInitialized = false;
        currentPageNumber = 0;
        totalCount = 0;
        currentSearchTerm = searchInput.Trim();
        hasMoreReleases = false;
        loadedReleases.Clear();

        isLoading = true;
        await LoadNextPageAsync();
        isLoading = false;
    }

    private async Task LoadNextPageAsync()
    {
        var nextPageNumber = currentPageNumber + 1;
        var page = await ReleaseService.GetPagedReleasesAsync(
            searchInput,
            nextPageNumber,
            PageSize,
            includeUnpublished);

        currentPageNumber = page.PageNumber;
        totalCount = page.TotalCount;
        currentSearchTerm = page.SearchTerm;
        hasMoreReleases = page.PageNumber < page.TotalPages;

        if (page.Items.Count > 0)
        {
            loadedReleases.AddRange(page.Items);
        }
    }

    private static string GetReleaseArtworkUrl(string? coverImageUrl)
        => string.IsNullOrWhiteSpace(coverImageUrl)
            ? PlaceholderAlbumArtPath
            : coverImageUrl;

    private static bool IsUpcomingRelease(DateTimeOffset releaseDateUtc)
        => releaseDateUtc > DateTimeOffset.UtcNow;

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("axlReleasesPage.disposeInfiniteScroll");
        }
        catch
        {
        }

        dotNetReference?.Dispose();
    }
}
